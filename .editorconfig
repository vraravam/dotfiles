# File location: dotfiles repo root
# This should take precedence over ~/.editorconfig for all files in this repo.
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
tab_width = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = off

# JSON — no overrides needed; all [*] defaults are correct for JSON

# Markdown — trailing whitespace is semantically significant (two spaces = <br>), so do not
# trim it. Indentation in Markdown is structural (code fences, lists), not a style choice,
# so leave indent_size unset. All other [*] defaults apply.
[*.md]
trim_trailing_whitespace = false
indent_size = unset

# Shell scripts
[*.sh]
switch_case_indent = true
space_redirects = false
keep_padding = true

# Windows shell scripts — idiomatically use tabs and CRLF line endings
[*.{cmd,bat}]
indent_style = tab
end_of_line = crlf

# SQL — 4-space indent (sqlfluff, pgFormatter, and most SQL style guides default to 4)
[*.sql]
indent_size = 4

# XML and text plist — 4-space indent (W3C tooling and most XML formatters default to 4)
[*.{xml,plist}]
indent_size = 4

# Compiled zsh bytecode — binary; disable all text processing
[*.zwc]
charset = unset
trim_trailing_whitespace = false
insert_final_newline = false
indent_size = unset

[*.zwc.old]
charset = unset
trim_trailing_whitespace = false
insert_final_newline = false
indent_size = unset

# Auto-generated by ruby-lsp
[**/.ruby-lsp/**]
insert_final_newline = false

[.ruby-lsp/**]
insert_final_newline = false

# Vendored third-party vim plugin
[files/--HOME--/.vim/autoload/plug.vim]
indent_size = unset

# gitignore/gitattributes files — columns of patterns use alignment spaces, not indentation
[{.gitignore,.gitignore_global,custom.gitignore,gitignore_global,**/.gitignore,**/.gitignore_global,**/custom.gitignore}]
indent_size = unset

[{custom.gitattributes,**/.gitattributes,**/custom.gitattributes}]
indent_size = unset

[files/--HOME--/.gitignore_global]
indent_size = unset
