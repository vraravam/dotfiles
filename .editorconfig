# File location: dotfiles repo root
# This should take precedence over ~/.editorconfig for all files in this repo.
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
tab_width = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = off

[*.json]
insert_final_newline = false

[*.md]
insert_final_newline = false
trim_trailing_whitespace = false
indent_size = unset

[*.sh]
switch_case_indent = true
space_redirects = false
keep_padding = true

# Windows Shell scripts
[*.{cmd,bat}]
end_of_line = crlf

# Compiled zsh bytecode — binary files, skip formatting checks
[*.zwc]
trim_trailing_whitespace = false
indent_size = unset

[*.zwc.old]
trim_trailing_whitespace = false
indent_size = unset

# Auto-generated by ruby-lsp
[**/.ruby-lsp/**]
insert_final_newline = false

[.ruby-lsp/**]
insert_final_newline = false

# Vendored third-party vim plugin
[files/--HOME--/.vim/autoload/plug.vim]
indent_size = unset

# gitignore files — alignment spaces inside are not indentation
[{.gitignore,.gitignore_global,custom.gitignore,gitignore_global,**/.gitignore,**/.gitignore_global,**/custom.gitignore}]
indent_size = unset

[files/--HOME--/.gitignore_global]
indent_size = unset
