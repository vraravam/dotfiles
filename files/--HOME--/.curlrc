# file location: ${HOME}/.curlrc

# Do not wait for multiplexing
parallel-immediate

# Display transfer progress as a bar
progress-bar

# Maximum time allowed for transfer
max-time 150

# Retry only within this period
retry-max-time 60

# Retry request if transient problems occur
retry 3

# Retry on connection refused (with --retry)
retry-connrefused

# Wait time between retries
retry-delay 5

# Request compressed response
compressed

# Enable SSH compression
compressed-ssh

# Note: Commenting this out, since it causes the terminal app to close at the end of running 'fresh-install'
# retry on any/all errors
# retry-all-errors
