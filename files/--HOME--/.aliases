# Convenience wrappers that invoke the per-project script in PERSONAL_BIN_DIR
# corresponding to the current directory name, e.g. 'launch-ferdium.sh'.
launch_me() {
  "${PERSONAL_BIN_DIR}/launch-${PWD##*/}.sh"
}
debug_me() {
  # Runs the per-project debug script in PERSONAL_BIN_DIR for the current directory.
  "${PERSONAL_BIN_DIR}/debug-${PWD##*/}.sh"
}
build_me() {
  # Runs the per-project build script in PERSONAL_BIN_DIR for the current directory.
  "${PERSONAL_BIN_DIR}/build-${PWD##*/}.sh"
}

