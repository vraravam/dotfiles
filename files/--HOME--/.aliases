#!/usr/bin/env zsh

# vim:filetype=zsh syntax=zsh tabstop=2 shiftwidth=2 softtabstop=2 expandtab autoindent fileencoding=utf-8

################################################################################
# This file is sourced at the end of the .zshrc file and loads aliases & functions
#
# file location: ${HOME}/.aliases
# load order: .zshenv [.shellrc], .zshrc [.shellrc, .aliases [.shellrc]], .zlogin
################################################################################

# Guard against re-sourcing -- all call sites can unconditionally 'source ~/.aliases'
# without needing their own check. This return is a no-op cost (single builtin).
# ZSH_VERSION guard ensures the zsh-only '(( $+functions[...] ))' syntax is never
# evaluated by non-zsh runtimes (e.g. direnv's sandbox).
if [[ -n "${ZSH_VERSION-}" ]] && (($+functions[is_aliases_sourced])); then
  return
fi

# Dummy function to check if .aliases is sourced (mirrors is_shellrc_sourced in .shellrc)
is_aliases_sourced() {
  return 0
}

# execute 'DEBUG=true zsh' to debug the load order of the custom zsh configuration files
if [[ -n "${DEBUG:-}" ]]; then echo "loading ${0}"; fi

# Re-source guard is inside .shellrc itself -- safe to call unconditionally.
source "${HOME}/.shellrc"

# ---------------------------------------------------------------------------
# Homebrew keg-only paths
# ---------------------------------------------------------------------------

# Cache Homebrew bin/sbin and keg-only PATH/LDFLAGS/CPPFLAGS/PKG_CONFIG_PATH/MANPATH
# to avoid ~42 stat syscalls per interactive startup. Keyed on the mtime of
# ${HOMEBREW_PREFIX}/opt/ -- which changes on every brew install/remove -- so new
# keg-only installs are automatically reflected on the next shell start.
#
# All entries are built directly from the filesystem -- never derived from the current
# environment. This makes regeneration idempotent: running inside a shell that already
# has keg-only vars set (e.g. OpenCode inheriting the user's PATH) produces the same
# cache as running in a clean shell. The snapshot-and-delta approach this replaced was
# broken: a pre-populated PATH caused an empty delta (keg-only bins missing from cache)
# and inherited LDFLAGS caused doubled flags.
#
# Moved from .zshrc to .aliases so it benefits from the re-source guard (runs once per
# shell session instead of on every .zshrc source). Only matters after brew is installed.
if (($+commands[brew])); then
  # Anonymous function scopes keg-only path computation locals; .aliases is zsh-only.
  () {
    local keg_cache="${XDG_CACHE_HOME}/keg-only-paths-cache.zsh"
    local opt_dir="${HOMEBREW_PREFIX}/opt"

    # Cache hit: source pre-computed static exports -- zero stat calls.
    # Inverted logic: is_file_older_than returns true when regeneration needed, so negate it.
    if ! is_file_older_than "${keg_cache}" "${opt_dir}"; then
      load_file_if_exists "${keg_cache}"
      return
    fi

    # Cache absent or stale: enumerate each keg-only package's directories directly.
    # keg_paths/keg_manpath are built with prepend semantics so the last-processed
    # package's entries appear first (highest PATH priority). Within each package,
    # gnubin is prepended last so it wins over libexec/bin which wins over bin.
    # ldflags_new/cppflags_new/pkgconfig_new accumulate only keg-only contributions
    # (not inherited environment values) -- the keg-only block is their sole setter
    # during startup, so these can be safely overwritten in the cache.
    local -a keg_paths=()
    local -a keg_manpath=()
    local ldflags_new=''
    local cppflags_new=''
    local pkgconfig_new=''

    # Named function required -- anonymous () cannot be called repeatedly in a loop.
    # Unfunctioned immediately after use to prevent global namespace pollution
    # (named functions defined inside () persist in the global table after return).
    _keg_collect() {
      local d="${HOMEBREW_PREFIX}/opt/${1:-}"
      if ! is_directory "${d}"; then return 0; fi
      if is_directory "${d}/bin"; then keg_paths=("${d}/bin" "${keg_paths[@]}"); fi
      if is_directory "${d}/libexec/bin"; then keg_paths=("${d}/libexec/bin" "${keg_paths[@]}"); fi
      if is_directory "${d}/libexec/gnubin"; then keg_paths=("${d}/libexec/gnubin" "${keg_paths[@]}"); fi
      if is_directory "${d}/libexec/gnuman"; then keg_manpath=("${d}/libexec/gnuman" "${keg_manpath[@]}"); fi
      if is_directory "${d}/lib"; then ldflags_new="-L${d}/lib${ldflags_new:+ ${ldflags_new}}"; fi
      if is_directory "${d}/include"; then cppflags_new="-I${d}/include${cppflags_new:+ ${cppflags_new}}"; fi
      if is_directory "${d}/lib/pkgconfig"; then pkgconfig_new="${d}/lib/pkgconfig${pkgconfig_new:+:${pkgconfig_new}}"; fi
    }
    local pkg
    for pkg in 'curl' 'gnu-tar' 'grep' 'sqlite' 'zlib'; do
      _keg_collect "${pkg}"
    done
    if is_directory "${HOMEBREW_PREFIX}/opt/openssl@3"; then
      _keg_collect 'openssl@3'
      export RUBY_CONFIGURE_OPTS="--with-openssl-dir=${HOMEBREW_PREFIX}/opt/openssl@3"
    fi
    unfunction _keg_collect

    # Homebrew base bin/sbin appended after keg-only entries so keg-only tools take
    # priority. sbin is placed before bin to match the original prepend sequence
    # (bin prepended first, sbin prepended second → sbin ends up in front of bin).
    # /etc/paths.d/homebrew pre-populates /opt/homebrew/bin at a low priority position;
    # it is re-added here at the front. typeset -gU path at the bottom removes the dup.
    # Desired order: mise (_mise_hook via zsh-defer) > keg-only > homebrew base > system.
    local -a hb_base=()
    if is_directory "${HOMEBREW_PREFIX}/bin"; then hb_base+=("${HOMEBREW_PREFIX}/bin"); fi
    if is_directory "${HOMEBREW_PREFIX}/sbin"; then hb_base=("${HOMEBREW_PREFIX}/sbin" "${hb_base[@]}"); fi

    # homebrew share/man after keg-only gnuman entries.
    if is_directory "${HOMEBREW_PREFIX}/share/man"; then keg_manpath+=("${HOMEBREW_PREFIX}/share/man"); fi

    local -a all_path_entries=("${keg_paths[@]}" "${hb_base[@]}")

    # Apply to the current session.
    if is_non_empty_array all_path_entries; then path=("${all_path_entries[@]}" "${path[@]}"); fi
    if is_non_empty_array keg_manpath; then manpath=("${keg_manpath[@]}" "${manpath[@]}"); fi
    if is_non_zero_string "${ldflags_new}"; then export LDFLAGS="${ldflags_new}"; fi
    if is_non_zero_string "${cppflags_new}"; then export CPPFLAGS="${cppflags_new}"; fi
    if is_non_zero_string "${pkgconfig_new}"; then export PKG_CONFIG_PATH="${pkgconfig_new}"; fi

    # Write static cache. Path/manpath entries are quoted for safe embedding.
    # LDFLAGS/CPPFLAGS/PKG_CONFIG_PATH are written as plain overwrites (no
    # ${LDFLAGS} expansion) -- they contain only keg-only contributions and are
    # safe to overwrite because nothing else in the startup sequence sets them.
    {
      local -a qpaths=() qmanpath=()
      local entry
      for entry in "${all_path_entries[@]}"; do qpaths+=("${(q)entry}"); done
      for entry in "${keg_manpath[@]}"; do qmanpath+=("${(q)entry}"); done
      if is_non_empty_array qpaths; then
        printf 'path=(%s "${path[@]}")\n' "${qpaths[*]}"
      fi
      if is_non_empty_array qmanpath; then
        printf 'manpath=(%s "${manpath[@]}")\n' "${qmanpath[*]}"
      fi
      if is_non_zero_string "${ldflags_new}"; then
        printf 'export LDFLAGS=%s\n' "${(q)ldflags_new}"
      fi
      if is_non_zero_string "${cppflags_new}"; then
        printf 'export CPPFLAGS=%s\n' "${(q)cppflags_new}"
      fi
      if is_non_zero_string "${pkgconfig_new}"; then
        printf 'export PKG_CONFIG_PATH=%s\n' "${(q)pkgconfig_new}"
      fi
      if is_non_zero_string "${RUBY_CONFIGURE_OPTS:-}"; then
        printf 'export RUBY_CONFIGURE_OPTS=%s\n' "${(q)RUBY_CONFIGURE_OPTS}"
      fi
    } >|"${keg_cache}" 2>/dev/null
  }
fi

# --------------------------------------------------------------------------
# Editor configuration
# --------------------------------------------------------------------------

unset GIT_EDITOR
# SSH sessions fall back to vi; local sessions prefer GUI editors.
# EDITOR always delegates to wait-editor, which re-execs $GIT_EDITOR via POSIX
# word-splitting -- so '--wait' flags are passed correctly to GUI editors, and
# vi (which blocks naturally) works without any special casing.
if is_non_zero_string "${SSH_CONNECTION:-}"; then
  preferred_editors=('vi')
else
  preferred_editors=('zed --wait' 'code --wait' 'vi')
fi
for editor in "${preferred_editors[@]}"; do
  # ${editor%% *} strips everything after the first space -- pure zsh, no fork.
  # (($+commands[...])) is a single O(1) hash probe; command_exists does 4.
  # .aliases is zsh-only; all three candidates (zed, code, vi) are external
  # binaries -- $+commands is the right table to probe.
  if (($+commands[${editor%% *}])); then
    export GIT_EDITOR="${editor}"
    break
  fi
done
unset preferred_editors editor
# Safety net: if no editor was found in PATH (e.g. a stripped environment
# where even vi is absent), fall back to vi unconditionally so GIT_EDITOR is
# never left unset. wait-editor will fail clearly if vi is truly missing.
if is_zero_string "${GIT_EDITOR:-}"; then
  export GIT_EDITOR='vi'
fi
# EDITOR is always the wait-editor wrapper regardless of which editor was
# selected -- set once here rather than repeating it in every branch above.
export EDITOR='wait-editor'

# Editor aliases
# EDITOR='wait-editor' -- a wrapper script that re-execs $GIT_EDITOR with word-splitting
# so --wait is passed correctly to tools that exec() EDITOR directly (crontab, visudo, etc.).
# GIT_EDITOR carries the full invocation with flags (e.g. 'zed --wait').
if command_exists "${EDITOR:-}"; then
  if is_zsh; then
    # associate file extensions with applications for the 'open' command
    alias -s txt="${EDITOR}"
    alias -s log="${EDITOR}"
  fi

  # add a generic alias for editing files and folders -- non-blocking (bare binary,
  # no --wait) so the shell prompt returns immediately after launching the editor.
  # Non-blocking: strip flags (e.g. 'zed --wait' → 'zed') via nested expansion.
  # Falls back to $EDITOR if GIT_EDITOR is unset (e.g. non-interactive shells).
  alias edit="${${GIT_EDITOR:-${EDITOR}}%% *}"

  # opens the relevant files and folders (used for laptop provisioning) in a single VSCode session
  alias edit-gist='edit "${DOTFILES_DIR}" "${PERSONAL_BIN_DIR}" "${PERSONAL_CONFIGS_DIR}" "${HOME}"/.gitconfig-* "${HOME}/.gitignore" "${HOME}/.ssh" "${HOME}/.mise.toml" "${PERSONAL_PROFILES_DIR}/.gitignore"'
fi

# Make VSCodium use the VS Code marketplace
if (($+commands[codium])); then
  export VSCODE_GALLERY_SERVICE_URL='https://marketplace.visualstudio.com/_apis/public/gallery'
  export VSCODE_GALLERY_CACHE_URL='https://vscode.blob.core.windows.net/gallery/index'
  export VSCODE_GALLERY_ITEM_URL='https://marketplace.visualstudio.com/items'
  export VSCODE_GALLERY_CONTROL_URL=''
  export VSCODE_GALLERY_RECOMMENDATIONS_URL=''
fi

# Use bat to colorize man pages
if (($+commands[bat])); then
  export MANPAGER="sh -c 'col -bx | bat -l man -p'"
fi

# Defines word-boundaries for editing: ensures that deleting word on /path/to/file
# deletes only 'file' and not the directory. This removes '/' and '.' from $WORDCHARS.
export WORDCHARS="${WORDCHARS:s#/#}"
export WORDCHARS="${WORDCHARS:s#.#}"

# --------------------------------------------------------------------------
# String utilities (zsh-only; not needed in direnv/bash so lives here not .shellrc)
# --------------------------------------------------------------------------

# Returns the last path segment of $1, stripping any trailing slash.
# Uses pure-zsh nested expansion -- safe here since .aliases is never sourced by bash.
# Usage: extract_last_segment <path>
extract_last_segment() {
  echo "${"${1%/}"##*/}"
}

# --------------------------------------------------------------------------
# Script utilities (zsh-only; not needed before dotfiles repo is cloned)
# --------------------------------------------------------------------------

# Parses positional args into 'folder' (first non-switch arg, defaulting to
# pwd) and 'switches' (all --flag args). Callers must declare both locals
# before calling this function so the assignments land in their scope.
#
# Usage:
#   local folder
#   local -a switches
#   parse_folder_and_switches "$@"
parse_folder_and_switches() {
  folder=''
  switches=()
  for arg in "$@"; do
    if [[ "${arg}" == --* ]]; then
      switches+=("${arg}")
    elif is_zero_string "${folder}"; then
      folder="${arg}"
    fi
  done
  # ${PWD} is a POSIX standard variable -- always set in bash, zsh, and cron.
  # Avoids the $(pwd) subprocess fork that fires on every call when no folder arg
  # is given (the common case for push/pull/upreb/cc and similar autoload functions).
  folder="${folder:-${PWD}}"
}

# Sources ${PERSONAL_BIN_DIR}/<cmd>-<cwd-basename>.sh if it exists and is
# executable; otherwise falls back to calling <fallback_fn> with all args.
#
# Usage: dispatch_or_fallback <cmd> <fallback_fn> "$@"
#
# Example (in the 'push' autoload):
#   push() { dispatch_or_fallback push _push "$@"; }
dispatch_or_fallback() {
  local cmd="${1:-}"
  local fallback_fn="${2:-}"
  shift 2
  local override="${PERSONAL_BIN_DIR}/${cmd}-${PWD##*/}.sh"
  if is_executable "${override}"; then
    . "${override}" "$@"
  else
    "${fallback_fn}" "$@"
  fi
}

# Creates a new shell script with standard header boilerplate.
# Usage: new_script <path> [shell_type]
#   shell_type: 'zsh' (default) or 'bash'
new_script() {
  local script_path="${1:?Script path required}"
  local shell_type="${2:-zsh}"

  if is_file "${script_path}"; then
    error "File already exists: ${script_path}"
    return 1
  fi

  local dir="${script_path:h}"
  if ! is_directory "${dir}"; then
    error "Directory does not exist: ${dir}"
    return 1
  fi

  cat >"${script_path}" <<EOF
#!/usr/bin/env ${shell_type}

# vim:filetype=${shell_type} syntax=${shell_type} tabstop=2 shiftwidth=2 softtabstop=2 expandtab autoindent fileencoding=utf-8

set -euo pipefail

# TODO: Add your code here
EOF

  chmod +x "${script_path}"
  success "Created new ${shell_type} script: ${script_path}"
}

# Validates that a required environment variable is set.
# Usage: require_env_var VAR_NAME [VAR_NAME2 ...]
#
# Example:
#   require_env_var PERSONAL_BIN_DIR DOTFILES_DIR
require_env_var() {
  local var_name
  for var_name in "$@"; do
    if is_zero_string "${(P)var_name:-}"; then
      warn "'$(yellow "${var_name}")' must be set in either '$(cyan "~/.shellrc")' or '$(cyan "~/.aliases")'
  After adding, run:
    - unfunction is_shellrc_sourced; zcompile ~/.shellrc; source ~/.shellrc
    - unfunction is_aliases_sourced; zcompile ~/.aliases; source ~/.aliases"
      return 1
    fi
  done
}

# --------------------------------------------------------------------------
# GROUP 3: Ongoing Daily-Use Aliases & Functions
# (Groups 1 and 2 are defined in .shellrc -- bootstrap utilities and core predicates.)
# Loaded after .shellrc via .zshrc. These are convenience wrappers, maintenance
# tools, and project-specific helpers used during interactive shell sessions.
# --------------------------------------------------------------------------

# --------------------------------------------------------------------------
# 3a. Shell defaults -- extended flags on built-in commands
# --------------------------------------------------------------------------
alias less="${aliases[less]:-less} -RF"
alias cp="${aliases[cp]:-cp} -p"
alias mkdir="${aliases[mkdir]:-mkdir} -p"
alias grep="${aliases[grep]:-grep} -Hn --color=auto --exclude-dir={.zsh_sessions,.IdentityService,.Trash} --exclude={\".*history\",\".zcompdump*\",\"*.zwc*\",\".*.zwc*\"}"
alias fgrep="${aliases[fgrep]:-fgrep} -Hn --color=auto --exclude-dir={.zsh_sessions,.IdentityService,.Trash} --exclude={\".*history\",\".zcompdump*\",\"*.zwc*\",\".*.zwc*\"}"
alias egrep="${aliases[egrep]:-egrep} -Hn --color=auto --exclude-dir={.zsh_sessions,.IdentityService,.Trash} --exclude={\".*history\",\".zcompdump*\",\"*.zwc*\",\".*.zwc*\"}"

# --------------------------------------------------------------------------
# 3b. Tool replacements -- enhanced CLI tools
# --------------------------------------------------------------------------
# eza already defines 'll' - so skip if that's present
if ! command_exists eza; then alias ll='ls -la'; fi
if command_exists tree; then alias tree="${aliases[tree]:-tree} -Ch"; fi
if command_exists vim; then alias vi='vim'; fi
if command_exists prettyping; then alias ping='prettyping --nolegend'; fi
if command_exists bat; then alias cat='bat'; fi
if command_exists btop; then alias top='btop'; fi
if command_exists ncdu; then alias du='ncdu --color dark -r -x --exclude .git --exclude .svn --exclude node_modules --exclude .npm --exclude .nuget --exclude Library'; fi

# --------------------------------------------------------------------------
# Helper functions for delegating to Ruby utilities
# --------------------------------------------------------------------------

# Internal helper: calls a Ruby Repos module method with keyword arguments.
# Eliminates duplication of $LOAD_PATH setup across repo wrapper functions.
# Usage: _call_ruby_git_workspace <method_name> <key1>=<value1> [<key2>=<value2> ...]
# Example: _call_ruby_git_workspace install_mise_versions first_install=true
#          _call_ruby_git_workspace regenerate_repo_aliases force=false
_call_ruby_git_workspace() {
  local method="${1:-}"
  if is_zero_string "${method}"; then
    error '_call_ruby_git_workspace: method name required'
    return 1
  fi
  shift

  # Guard: Ruby must be available (vanilla OS before Homebrew installs it)
  if ! command_exists ruby; then
    debug "Ruby not available -- skipping GitWorkspace.${method}"
    return 0
  fi

  local kwargs_str=""
  if [[ $# -gt 0 ]]; then
    # Build comma-separated list of keyword arguments: key1: value1, key2: value2
    # Each arg is expected in "key=value" format
    local -a kwargs_parts=()
    for arg in "$@"; do
      local key="${arg%%=*}"
      local value="${arg#*=}"
      kwargs_parts+=("${key}: ${value}")
    done
    # Join with ', '
    local IFS=', '
    kwargs_str="${kwargs_parts[*]}"
  fi

  setup_rubylib
  ruby -e "require 'git_workspace'; GitWorkspace.${method}(${kwargs_str})"
}

# --------------------------------------------------------------------------
# 3c. Multi-repo git shortcuts (via run-all.rb)
# --------------------------------------------------------------------------
if command_exists 'run-all.rb'; then
  # shortcuts to handle multiple git repos
  alias rug='run-all.rb git'
  alias all="FOLDER='${HOME}' MAXDEPTH=7 rug"
  alias all-cache="FILTER='[cC]ache' all"
  alias home="FOLDER='${HOME}' FILTER='.bin|.dotfiles|zsh|mise' MAXDEPTH=5 rug"
  if is_directory "${PERSONAL_PROFILES_DIR}"; then
    alias profiles="FOLDER='${PERSONAL_PROFILES_DIR}' MAXDEPTH=5 rug"
  fi

  # Regenerates the repo alias cache and re-sources it in the current shell.
  # Without -f: silent; only rebuilds if the cache is missing or stale.
  # With -f:    always rebuilds and prints progress (use after adding/removing nested project dirs).
  regenerate_repo_aliases() {
    is_directory "${PROJECTS_BASE_DIR}" || return 0

    local force_flag="false"
    if [[ "${1-}" == "-f" ]]; then force_flag="true"; fi

    # Delegate to Ruby implementation in utilities/git_workspace.rb
    _call_ruby_git_workspace regenerate_repo_aliases "force=${force_flag}"

    # Load the generated cache
    local repo_alias_cache="${XDG_CACHE_HOME}/repo-aliases-cache.zsh"
    load_file_if_exists "${repo_alias_cache}"
  }

  regenerate_repo_aliases
fi

# --------------------------------------------------------------------------
# 3d. Cache & cleanup
# --------------------------------------------------------------------------

# Deletes all compiled zsh bytecode (*.zwc*) files under HOME and HOMEBREW_PREFIX, and
# removes the entire XDG_CACHE_HOME directory. Cache files (brew shellenv, starship init,
# repo aliases, etc.) are recreated on the next shell start; *.zwc bytecode files are
# recompiled only on the next login shell (via .zlogin).
delete_caches() {
  # Delete all *.zwc* compiled zsh bytecode files under HOME and HOMEBREW_PREFIX so
  # they are recompiled fresh on the next login shell (via .zlogin).  This covers
  # compiled config files, scripts, autoload functions, and any *.zwc siblings of
  # the cache files below.
  #
  # Two separate find calls are required: HOME is searched without -L (no symlink
  # following) to avoid cycles in user home dirs. HOMEBREW_PREFIX must use -L so
  # that find descends into opt/<formula>/ directories, which are all symlinks to
  # Cellar/<formula>/<version>/. Without -L, stale .zwc files in those paths are
  # silently skipped -- antidote.zsh.zwc in particular must be purged so that
  # antidote's ZSH_EVAL_CONTEXT source-detection check works correctly on next start.
  find "${HOME}" -maxdepth 10 \( -path '*/.git/*' -o -path '*/node_modules/*' -o -path '*/.mypy_cache/*' -o -path '*/__pycache__/*' \) -prune -o -name '*.zwc*' -type f -print -delete || warn "find command failed in ${HOME}"
  # macOS find forbids -delete when -L is active (safety guard against deleting
  # symlink targets). Use -exec rm -f instead, which is exempt from this restriction.
  find -L "${HOMEBREW_PREFIX}" -maxdepth 10 \( -path '*/.git/*' -o -path '*/node_modules/*' -o -path '*/.mypy_cache/*' -o -path '*/__pycache__/*' \) -prune -o -name '*.zwc*' -type f -print -exec rm -f {} + || warn "find command failed in ${HOMEBREW_PREFIX}"

  # Delete the entire XDG_CACHE_HOME directory. This removes all generated cache
  # files (brew-shellenv-cache.zsh, starship-init-cache.zsh, repo-aliases-cache.zsh, zsh
  # completion dump, fast-syntax-highlighting theme cache, etc.) and their *.zwc
  # bytecode companions. They are all regenerated automatically on the next shell
  # start or login shell.  .zshrc recreates XDG_CACHE_HOME with mkdir -p before
  # any cache write, so the missing directory is safe.
  if is_directory "${XDG_CACHE_HOME}"; then
    rm -rfv "${XDG_CACHE_HOME}"

    # Ensure XDG_CACHE_HOME exists before any cache writes below. When ${XDG_CACHE_HOME} is removed above,
    # the subsequent cache-write redirections (>|) silently fail and leave caches empty -- breaking fpath
    # updates and other lazy-loaded config that only runs through the cache file.
    ensure_dir_exists "${XDG_CACHE_HOME}"
  fi

  # Re-source .zlogin immediately to rebuild all .zwc caches in the current shell.
  # Without this, the first new terminal after delete_caches opens with no .zwc files;
  # raw-source startup leaves the function table in a state where helper functions
  # (e.g. is_debug) are not yet visible to the background subshell spawned by
  # .zlogin's recompile block, producing "command not found: is_debug" errors.
  # Sourcing here pre-builds every .zwc so subsequent terminals load from bytecode.
  source "${ZDOTDIR}/.zlogin"

  # Belt-and-suspenders: explicitly recompile the two most-critical startup files
  # after .zlogin returns. .zlogin's recompile_zsh_scripts handles both files
  # synchronously, but a stale .zwc compiled from an older source (e.g. after a
  # git pull that modified .shellrc while a terminal was open) can survive across
  # sessions if the mtime check happens to pass with the wrong cached file.
  # A direct zcompile here always writes a fresh .zwc from the current source,
  # guaranteeing delete_caches leaves the two most-loaded files in a known-good state.
  zcompile "${HOME}/.shellrc"
  zcompile "${HOME}/.aliases"
}

# --------------------------------------------------------------------------
# 3e. Repo management & environment setup
# --------------------------------------------------------------------------

# Clones all repositories listed in repositories-*.yml catalogue files under
# PERSONAL_CONFIGS_DIR, then runs post-clone operations (restore-mtime, git
# maintenance register/start, setup_dev_environment).
resurrect_tracked_repos() {
  # Deferred-collection locals. _SCRIPT_NAME is read by logging functions via
  # dynamic scoping (no argument passing needed). _current_section is declared
  # for consistency with scripts using deferred collection but not used here.
  # _step_warnings and _step_errors accumulate issues for the final summary.
  local _SCRIPT_NAME='resurrect_tracked_repos'
  local _current_section='(init)'
  local -a _step_warnings=()
  local -a _step_errors=()

  # Increment script depth and register decrement trap. This ensures that when
  # called directly from the command line, this function acts as the outermost
  # script (depth 1, prints banners). When called from fresh-install-of-osx.sh
  # (which already incremented to depth 1), this increments to depth 2 and
  # suppresses nested script banners from resurrect-repositories.rb.
  export _DOTFILES_SCRIPT_DEPTH=$((${_DOTFILES_SCRIPT_DEPTH:-0} + 1))
  # Shell functions cannot set EXIT traps -- they only fire on process exit, not
  # function return. The manual decrement at the end is the correct pattern for
  # functions. Scripts use 'trap _decrement_script_depth EXIT'.

  local script_start_time="${EPOCHSECONDS}"
  print_script_start

  if is_non_zero_string "${PERSONAL_CONFIGS_DIR}"; then
    # TODO: Add the github.com host to the known_hosts file so that the script is not blocked for user input
    # ssh-keyscan -H -t ED25519 github.com >> "${HOME}/.ssh/known_hosts"

    # resurrect repositories that are in the repo catalogues
    section_header2 "$(yellow 'Resurrecting all tracked git repos')"
    _current_section='Resurrecting all tracked git repos'
    # Use zsh glob qualifier (N.) for nullglob and regular files
    local file
    local -a failed_files=()
    for file in "${PERSONAL_CONFIGS_DIR}"/repositories-*.yml(N.); do
      if ! resurrect-repositories.rb -r "${file}"; then
        # Transform and store failed files: replace HOME with ~ and colorize in red
        failed_files+=("$(red "$(replace_home_with_tilde "${file}")")")
      fi
    done
    # resurrect-repositories.rb exits non-zero if there are any failures OR
    # warnings (fetch failures, post-clone failures, etc.), so failed_files
    # will contain any yaml file that had issues.
    if is_empty_array failed_files; then
      success 'Successfully resurrected all tracked git repos'
    else
      local msg="$(red "Failed to process ${#failed_files[@]} file(s):")"
      msg+=$'\n'"$(join_array failed_files)"
      # Append directly to _step_warnings instead of calling _record_warning
      # to avoid duplicate output (don't print immediately, only in final summary)
      _step_warnings+=("[${_SCRIPT_NAME}][${_current_section}] ${msg}")
    fi
  else
    debug "Skipping resurrecting of repositories since '$(cyan "${PERSONAL_CONFIGS_DIR}")' doesn't exist"
  fi

  # post-clone operations for installing system dependencies
  section_header2 "$(yellow 'Running post-clone operations')"
  # 'all' (alias: FOLDER='${HOME}' MAXDEPTH=7 rug → run-all.rb git) requires .aliases
  # to be loaded so the alias is defined. Use the underlying command directly to avoid
  # that dependency -- this function is called from fresh-install as a background job
  # where the sourcing order may differ.
  if command_exists 'run-all.rb'; then
    FOLDER="${HOME}" MAXDEPTH=7 run-all.rb 'git restore-mtime -c'
    FOLDER="${HOME}" MAXDEPTH=7 run-all.rb "git maintenance register --config-file '${HOME}/.gitconfig-oss.inc'"
    FOLDER="${HOME}" MAXDEPTH=7 run-all.rb 'git maintenance start'
  fi

  setup_dev_environment

  regenerate_repo_aliases

  # Only print success message if there were no warnings/errors. print_script_summary
  # will show the warnings/errors section if any were recorded.
  local summary_msg=''
  if is_empty_array _step_warnings && is_empty_array _step_errors; then
    summary_msg='Finished resurrecting tracked repos'
  fi
  print_script_summary "${script_start_time}" "${summary_msg}"
  # Manual decrement -- EXIT trap does not fire on function return in shell functions.
  _decrement_script_depth
}

# Internal helper: calls a Ruby GitWorkspace module method with optional arguments.
# Installs any missing tool versions declared via mise config files (.mise.toml,
# .tool-versions, etc.) across all git repos and their ancestor directories under
# HOME, DOTFILES_DIR, and PROJECTS_BASE_DIR. Skips silently if mise is not in PATH.
# Thin wrapper that delegates to Ruby GitWorkspace.install_mise_versions.
install_mise_versions() {
  if ! command_exists mise; then
    debug "Couldn't find 'mise' in the PATH; Skipping loading any mise configs"
    return 0
  fi
  local first_install_flag="false"
  if is_first_install; then first_install_flag="true"; fi
  _call_ruby_git_workspace install_mise_versions "first_install=${first_install_flag}"
}

# Runs 'direnv allow' for every directory that has an .envrc file across all
# git repos and their ancestor directories under HOME, DOTFILES_DIR, and
# PROJECTS_BASE_DIR. Skips silently if direnv is not in PATH.
# Thin wrapper that delegates to Ruby GitWorkspace.allow_all_direnv_configs.
allow_all_direnv_configs() {
  if ! command_exists direnv; then
    debug "Couldn't find 'direnv' in the PATH; Skipping allowing any direnv configs"
    return 0
  fi
  local first_install_flag="false"
  if is_first_install; then first_install_flag="true"; fi
  _call_ruby_git_workspace allow_all_direnv_configs "first_install=${first_install_flag}"
}

# Runs both direnv authorization and mise installation in a single optimized pass.
# Collects git repos and ancestor directories once (instead of twice), saving
# 200-500ms per run by avoiding redundant filesystem traversals.
# Thin wrapper that delegates to Ruby GitWorkspace.setup_dev_environment.
setup_dev_environment() {
  local first_install_flag="false"
  if is_first_install; then first_install_flag="true"; fi
  _call_ruby_git_workspace setup_dev_environment "first_install=${first_install_flag}"
}

# --------------------------------------------------------------------------
# 3f. Network utilities (macOS + Linux)
# --------------------------------------------------------------------------

# Spoofs the MAC address of the given network interface to a random value, which can
# bypass MAC-address-based session limits on captive-portal (free) Wi-Fi networks.
# Prints the old and new MAC address for confirmation.
# Usage: _free_wifi <interface>  (called via the free_wifi alias, e.g. free_wifi en0)
_free_wifi() {
  local interface="${1:-}"
  (ifconfig "${interface}" | /usr/bin/grep ether) &&
    (openssl rand -hex 6 | sed 's/\(..\)/\1:/g; s/.$//' | xargs sudo ifconfig "${interface}" ether) &&
    (ifconfig "${interface}" | /usr/bin/grep ether)
}

if is_macos; then
  alias free_wifi='_free_wifi en0'

  alias flush_dns='sudo killall -HUP mDNSResponder;sudo killall mDNSResponderHelper;sudo dscacheutil -flushcache;say MacOS DNS cache has been cleared'

  # MacOS: Remove apps from quarantine
  unquarantine() {
    xattr -rd com.apple.quarantine "${@}"
    open "${@}"
  }

  # MacOS: Clean up LaunchServices to remove duplicates in the "Open With" menu
  alias cleanup_launch_services='/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister -kill -r -domain local -domain system -domain user && killall Finder'

  # Show/hide hidden files in Finder
  alias show_hidden_files='defaults write com.apple.finder AppleShowAllFiles -bool true && killall Finder'
  alias hide_hidden_files='defaults write com.apple.finder AppleShowAllFiles -bool false && killall Finder'

  # Hide/show all desktop icons (useful when presenting)
  alias hide_desktop='defaults write com.apple.finder CreateDesktop -bool false && killall Finder'
  alias show_desktop='defaults write com.apple.finder CreateDesktop -bool true && killall Finder'

  # Finds and appends the preferences associated with the partial string passed in as an argument.
  # Also, sorts (and removes duplicates) from the config file used to capture preferences.
  # Warns (and does NOT append) if the discovered domain is on the denied list of
  # machine-specific/account-bound domains defined in capture-prefs-denied-list.txt.
  # Usage: find_and_append_prefs <search-string>
  find_and_append_prefs() {
    local allowed_list_file="${DOTFILES_DIR}/scripts/data/capture-prefs-allowed-list.txt"
    local denied_list_file="${DOTFILES_DIR}/scripts/data/capture-prefs-denied-list.txt"
    defaults find "${1:-}" | /usr/bin/grep 'keys in domain' | while IFS="'" read -r _ field _; do
      # Check whether this domain is on the denied list before appending.
      if /usr/bin/grep -Fxq "${field}" "${denied_list_file}" 2>/dev/null; then
        debug "Skipping '$(yellow "${field}")' -- it is on the denied list (machine-specific data; see capture-prefs-denied-list.txt)"
      else
        print -- "${field}" >>"${allowed_list_file}"
      fi
    done
    sort -u -o "${allowed_list_file}" "${allowed_list_file}"
  }
elif is_linux; then
  alias free_wifi='_free_wifi eth0'
fi

# --------------------------------------------------------------------------
# 3g. Homebrew utilities
# --------------------------------------------------------------------------

if is_macos && command_exists brew; then
  trust_brewfile_items() {
    # Trust specific formulae and casks from custom taps that are referenced in Brewfile.
    # This ensures only explicitly-used items are trusted (not entire taps), which follows
    # the principle of least privilege when HOMEBREW_REQUIRE_TAP_TRUST is enforced.
    # Uses 'brew untrust' CLI to identify untrusted items.
    if command_exists brew; then
      local -a untrusted_formulae
      local -a untrusted_casks
      local -a brewfile_formulae
      local -a brewfile_casks

      # Get formulae and casks from Brewfile
      brewfile_formulae=($(brew bundle list --file="${HOMEBREW_BUNDLE_FILE}" --formula 2>/dev/null))
      brewfile_casks=($(brew bundle list --file="${HOMEBREW_BUNDLE_FILE}" --casks 2>/dev/null))

      # Parse 'brew untrust' output to get untrusted formulae
      untrusted_formulae=($(brew untrust 2>&1 | awk '/^Untrusted formulae:/{flag=1;next}/^Untrusted [a-z]+:/{flag=0}flag{print $1}'))

      # Parse 'brew untrust' output to get untrusted casks
      untrusted_casks=($(brew untrust 2>&1 | awk '/^Untrusted casks:/{flag=1;next}/^Untrusted [a-z]+:/{flag=0}flag{print $1}'))

      # Trust untrusted formulae that are in Brewfile
      if is_non_empty_array untrusted_formulae && is_non_empty_array brewfile_formulae; then
        for formula in "${untrusted_formulae[@]}"; do
          # Brewfile contains short names; extract short name from full tap/formula name for comparison
          if printf '%s\n' "${brewfile_formulae[@]}" | /usr/bin/grep -Fxq "${formula##*/}"; then
            info "Trusting formula: '$(yellow "${formula}")'"
            brew trust --formula "${formula}" || true
          fi
        done
      fi

      # Trust untrusted casks that are in Brewfile
      if is_non_empty_array untrusted_casks && is_non_empty_array brewfile_casks; then
        for cask in "${untrusted_casks[@]}"; do
          # Brewfile contains short names; extract short name from full tap/cask name for comparison
          if printf '%s\n' "${brewfile_casks[@]}" | /usr/bin/grep -Fxq "${cask##*/}"; then
            info "Trusting cask: '$(yellow "${cask}")'"
            brew trust --cask "${cask}" || true
          fi
        done
      fi
    fi
  }

  # List all casks that are outdated like a "dry-run" (and which have version marked as 'latest')
  alias bcg='brew outdated --greedy'

  # Upgrades all casks that are outdated (and which have version marked as 'latest')
  alias bcug='brew upgrade --greedy'

  # Upgrades and cleans up all regular outdated casks and libs (non-greedy).
  # Antidote updates and tap trusting are handled via Brewfile postinstall hooks.
  bupc() {
    local _SCRIPT_NAME='bupc'
    local _current_section='(init)'
    local -a _step_warnings=()
    local -a _step_errors=()
    export _DOTFILES_SCRIPT_DEPTH=$((${_DOTFILES_SCRIPT_DEPTH:-0} + 1))
    # Shell functions cannot set EXIT traps -- they only fire on process exit, not
    # function return. The manual decrement at the end is the correct pattern for
    # functions. Scripts use 'trap _decrement_script_depth EXIT'.

    local start_time="${EPOCHSECONDS}"
    print_script_start

    # Trust any already-untrusted items from already-installed taps
    trust_brewfile_items

    # First pass: install taps and already-trusted formulae/casks
    # Suppress stderr since untrusted-tap errors are expected and fixed by second pass
    brew bundle check -v 2>/dev/null || brew bundle install -q 2>/dev/null || true

    # Trust any newly-untrusted items from newly-tapped taps (brew bundle may have installed new taps)
    # Hopefully this bug (https://github.com/Homebrew/brew/issues/22826) will fix the need to run this 2nd pass
    trust_brewfile_items

    # Second pass: install newly-trusted formulae/casks (idempotent if nothing new to trust)
    brew bundle check -v || brew bundle install -q || true

    brew bundle cleanup -f || true
    brew cleanup --prune=all || true
    brew autoremove || true
    brew upgrade || true

    # Third pass: Trust any newly-untrusted items from newly-tapped taps (brew bundle cleanup may have untrusted the taps)
    # logged a bug for this issue: https://github.com/Homebrew/brew/issues/22826
    trust_brewfile_items

    print_script_summary "${start_time}"
    # Manual decrement -- EXIT trap does not fire on function return in shell functions.
    _decrement_script_depth
  }

  # Thin wrapper that delegates to Ruby Antidote.update_and_regenerate_bundle.
  # Updates all installed antidote plugins, unshallows their git repos, and
  # regenerates the static bundle file.
  # Called by the antidote formula's postinstall hook in Brewfile (whenever
  # antidote is installed/upgraded) and by software-updates-cron.sh (periodic updates).
  update_antidote_and_regenerate_plugin_bundle() {
    setup_rubylib
    ruby -e "require 'antidote'; Antidote.update_and_regenerate_bundle"
  }

  # Audits and auto-styles a Homebrew cask formula for contribution readiness.
  # Usage: check_cask <cask-name>
  check_cask() {
    # shasum -a 256 <fileName>
    # cd $(brew --repository homebrew/cask-versions) &&
    if brew audit --online --cask "${1:-}"; then
      brew style --fix --cask "${1:-}"
    fi
    # cd -
    # brew fetch --cask "${1:-}"
  }

  # Builds a Homebrew formula from source, tests it, and audits it for contribution readiness.
  # Usage: check_formula <formula-name>
  check_formula() {
    brew install --build-from-source "${1:-}"
    brew test "${1:-}"
    brew audit --strict "${1:-}"
  }
fi

# --------------------------------------------------------------------------
# 3h. Diagnostic & utility functions
# --------------------------------------------------------------------------

# Benchmarks shell startup by launching ${SHELL} 10 times and printing timing for each.
# Reference: https://blog.jonlu.ca/posts/speeding-up-zsh
# Usage: time_shell_startup [shell-path]  (defaults to $SHELL)
time_shell_startup() {
  local shell_bin
  # Resolve via PATH so the result is the PATH-located binary, not a version
  # that may differ from what cron or a fresh login shell would use.
  shell_bin="$(which "$(basename "${1:-${SHELL}}")")"
  # {1..10} brace expansion -- no $(seq 1 10) subprocess fork.
  local i
  for i in {1..10}; do /usr/bin/time "${shell_bin}" -i -c exit; done
}

if command_exists docker; then
  # docker (TODO: Not sure why this is not done automatically by rancher when it starts up)
  # Note: can't use 'is_file' since testing for sockets is slightly different
  alias start_docker="test -S '${HOME}/.rd/docker.sock' && sudo ln -sf '${HOME}/.rd/docker.sock' /var/run/docker.sock"
  alias stop_docker="test -S /var/run/docker.sock && sudo rm -rf /var/run/docker.sock"
  alias docker_cleanup='docker system prune -a --volumes -f'
  alias docker_list='docker ps -a && docker images'

  show_docker_context_contents() {
    # Based on BMitch's answer from: https://stackoverflow.com/questions/38946683/how-to-test-dockerignore-file
    # Note: this will create and delete temporary file called 'Dockerfile.build-context'
    # Usage:
    # 1. Run this function in the project folder
    # 2. You should see list of files in build context
    # 3. If unwanted files are present, adjust the '.dockerignore' file and go back to step 1

    cat <<EOF >Dockerfile.build-context
  FROM busybox
  COPY . /build-context
  WORKDIR /build-context
  CMD ["find", "."]
EOF

    docker build -f Dockerfile.build-context -t build-context .
    docker run --rm build-context

    rm Dockerfile.build-context
  }
fi

# Converts a PDF file to a PNG image at maximum quality using ImageMagick.
# Usage: pdf_to_png <pdf-file>
pdf_to_png() {
  if [[ $# -ne 1 ]]; then
    warn "Usage: ${0} <pdf_file>"
    return 1 # Failure, invalid arguments
  fi

  if ! command_exists magick; then
    user_action 'Install imagemagick first!'
    return 0 # Success, nothing to do
  fi

  local pdf="${1:-}"
  local png="${pdf%.*}.png"

  magick -density 800 "${pdf}" -quality 100 "${png}"
}

