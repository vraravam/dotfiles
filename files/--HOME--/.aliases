# --------------------------------------------------------------------------
# 3n. macOS prefs helpers
# --------------------------------------------------------------------------

# Canonical list of login-item apps managed by osx-defaults.sh and
# capture-prefs.sh. Both scripts kill these apps before writing defaults so
# the running instance cannot overwrite writes on quit, and restart them on
# exit via an EXIT trap.
# Keep in sync with the Brewfile setup_login_items_script entries and the
# defaults-write login-key sections in osx-defaults.sh.
_MACOS_LOGIN_ITEM_APPS=(
  'Clocker'    # startAtLogin = true (com.abhishek.Clocker)
  'DockDoor'   # login item via Brewfile setup_login_items_script (SMAppService)
  'KeyCastr'   # login item via Brewfile setup_login_items_script (SMAppService)
  'KeyClu'     # launchAtLogin = true (com.0804Team.KeyClu)
  'Keybase'    # login item via Brewfile setup_login_items_script (SMAppService)
  'Mechvibes'  # login item via Brewfile setup_login_items_script (SMAppService)
  'Shortcat'   # login item via Brewfile setup_login_items_script (SMAppService)
  'Sol'        # login item via Brewfile setup_login_items_script (SMAppService)
  'Stats'      # LaunchAtLoginNext = true (eu.exelban.Stats)
  'Thaw'       # login item via Brewfile setup_login_items_script (SMAppService)
)

# Invokes a method on the MacOS Ruby module (scripts/utilities/macos.rb).
# Used by the delegation functions below to eliminate repetitive ruby -e calls.
#
# Arguments:
#   $1 - method name to call on MacOS module
_call_ruby_macos() {
  local method="${1:?_call_ruby_macos: method name required}"
  ruby -e "\$LOAD_PATH.unshift('${DOTFILES_DIR}/scripts/utilities'); require 'macos'; MacOS.${method}"
}

# Delegates to MacOS.kill_login_item_apps (scripts/utilities/macos.rb).
kill_login_item_apps() {
  _call_ruby_macos 'kill_login_item_apps'
}

# Delegates to MacOS.restart_login_item_apps (scripts/utilities/macos.rb).
restart_login_item_apps() {
  _call_ruby_macos 'restart_login_item_apps'
}

# Delegates to MacOS.suspend_softwareupdate_schedule (scripts/utilities/macos.rb).
suspend_softwareupdate_schedule() {
  _call_ruby_macos 'suspend_softwareupdate_schedule'
}

# Delegates to MacOS.resume_softwareupdate_schedule (scripts/utilities/macos.rb).
resume_softwareupdate_schedule() {
  _call_ruby_macos 'resume_softwareupdate_schedule'
}

# Delegates to MacOS.reload_macos_prefs (scripts/utilities/macos.rb).
reload_macos_prefs() {
  _call_ruby_macos 'reload_macos_prefs'
}
