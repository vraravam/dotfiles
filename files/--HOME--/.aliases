# --------------------------------------------------------------------------
# 3n. macOS prefs helpers
# --------------------------------------------------------------------------

# Canonical list of login-item apps managed by osx-defaults.sh and
# capture-prefs.sh. Both scripts kill these apps before writing defaults so
# the running instance cannot overwrite writes on quit, and restart them on
# exit via an EXIT trap.
# Keep in sync with the Brewfile setup_login_items_script entries and the
# defaults-write login-key sections in osx-defaults.sh.
_MACOS_LOGIN_ITEM_APPS=(
  'Clocker'    # startAtLogin = true (com.abhishek.Clocker)
  'DockDoor'   # login item via Brewfile setup_login_items_script (SMAppService)
  'KeyCastr'   # login item via Brewfile setup_login_items_script (SMAppService)
  'KeyClu'     # launchAtLogin = true (com.0804Team.KeyClu)
  'Keybase'    # login item via Brewfile setup_login_items_script (SMAppService)
  'Mechvibes'  # login item via Brewfile setup_login_items_script (SMAppService)
  'Shortcat'   # login item via Brewfile setup_login_items_script (SMAppService)
  'Sol'        # login item via Brewfile setup_login_items_script (SMAppService)
  'Stats'      # LaunchAtLoginNext = true (eu.exelban.Stats)
  'Thaw'       # login item via Brewfile setup_login_items_script (SMAppService)
)

# Sends SIGTERM to every app in _MACOS_LOGIN_ITEM_APPS. Called before writing
# defaults so in-memory state is flushed to disk first.
# Failures are silenced — apps that are not running are not an error.
kill_login_item_apps() {
  local _app
  for _app in "${_MACOS_LOGIN_ITEM_APPS[@]}"; do
    killall "${_app}" &>/dev/null || true
  done
  killall 'Finder' &>/dev/null || true  # launchd-managed; killall causes immediate relaunch
}

# Re-opens every app in _MACOS_LOGIN_ITEM_APPS. Called from an EXIT trap
# after defaults writes complete so the user is never left with login-item
# apps dead.
# Finder is launchd-managed: killall causes an immediate auto-relaunch with
# fresh prefs. open -a would be a no-op since launchd already relaunched it
# after kill_login_item_apps — so killall is used again here to force a
# second relaunch that reads the newly-written defaults.
restart_login_item_apps() {
  local _app
  for _app in "${_MACOS_LOGIN_ITEM_APPS[@]}"; do
    open -a "${_app}" &>/dev/null || true
  done
  killall 'Finder' &>/dev/null || true  # launchd-managed; killall causes immediate relaunch
}

# Turns the macOS automatic software update schedule off before reading/writing
# plists. Guards with 'sudo -n true' so it is safe to call from cron — if sudo
# credentials are not cached (no terminal), warns and skips rather than hanging.
# Must be paired with resume_softwareupdate_schedule (called from EXIT trap).
suspend_softwareupdate_schedule() {
  if ! has_sudo_credentials; then
    warn "suspend_softwareupdate_schedule: sudo credentials not available — skipping softwareupdate schedule suspension."
    return 0
  fi
  keep_sudo_alive
  sudo softwareupdate --schedule OFF
}

# Turns the macOS automatic software update schedule back on. Called from the
# EXIT trap in osx-defaults.sh and capture-prefs.sh so it runs on both normal
# and error exits. Guards with 'sudo -n true' so it is safe to call from cron —
# if sudo credentials are not cached (no terminal), warns and skips rather than
# hanging. keep_sudo_alive's duplicate-loop guard makes it a no-op when the
# background loop is already running.
resume_softwareupdate_schedule() {
  if ! has_sudo_credentials; then
    warn "resume_softwareupdate_schedule: sudo credentials not available — skipping softwareupdate schedule restoration."
    return 0
  fi
  keep_sudo_alive
  sudo softwareupdate --schedule ON
}

# Restarts the macOS system services that cache preferences so imported or
# written defaults take effect immediately without a logout.
# cfprefsd — flushes the global prefs cache (covers NSGlobalDomain).
# activateSettings — the only supported way to flush com.apple.symbolichotkeys
#   (keyboard shortcut changes) without a logout.
reload_macos_prefs() {
  local _reload_app
  for _reload_app in 'cfprefsd' 'Dock' 'Finder' 'SystemUIServer'; do
    killall "${_reload_app}" &>/dev/null || true
  done
  /System/Library/PrivateFrameworks/SystemAdministration.framework/Resources/activateSettings -u
}
