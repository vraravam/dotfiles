  alias tmuxa='tmux attach -t'          # attach to a named tmux session
fi

# --------------------------------------------------------------------------
# 3j. Cron management - dotfiles layer
#
# Contains the higher-level helpers that regenerate crontab from the canonical
# template stored in the dotfiles repo.  These functions reference DOTFILES_DIR,
# HOMEBREW_PREFIX, and PERSONAL_CONFIGS_DIR, so they are only safe to call
# after the dotfiles repo has been cloned and the full shell environment is set
# up (i.e. from within an interactive shell or late in fresh-install-of-osx.sh).
#
# The lower-level primitives (_DOTFILES_CRON_BACKUP_FILE, restore_cron, suspend_cron,
# resume_cron) live in .shellrc so they are available the moment .shellrc is
# sourced, well before the dotfiles repo exists.  See section 1h in .shellrc.
# --------------------------------------------------------------------------

# Internal: seeds crontab.txt at $1 with the standard env header and the
# software-updates-cron.sh schedule. Called by recron only when crontab.txt
# does not already exist (bootstrap / first-install path).
# Thin wrapper that delegates to Ruby Cron.create_crontab.
# Seeds the given file with the standard crontab header and the
# software-updates-cron schedule. Called by recron only when crontab.txt
# does not already exist (bootstrap / first-install path).
# Usage: create_crontab <output-file-path>
create_crontab() {
  local file="${1:-}"
  if is_zero_string "${file}"; then
    error "create_crontab requires an output file path as its first argument."
    return 1
  fi
  _call_ruby_cron create_crontab "${file}"
}

# Thin wrapper that delegates to Ruby Cron.recron.
# Loads the system crontab from ${PERSONAL_CONFIGS_DIR}/crontab.txt.
# If crontab.txt does not exist yet (bootstrap / first-install), seeds it first
# so there is always a known-good file on disk.
# Edit crontab.txt directly to change the schedule; recron will pick it up.
recron() {
  _call_ruby_cron recron
}

# Wraps a function call in the cron bracket: suspend cron, run the function,
# call recron to restore it, then clear the backup so the EXIT trap is a no-op.
#
# Usage: with_cron_suspended <fn> "$@"
#
# Example: with_cron_suspended _push "$@"
with_cron_suspended() {
  local fn="${1:-}"
  shift
  trap 'resume_cron' EXIT
  suspend_cron
  "${fn}" "$@"
  recron
  rm -f "${_DOTFILES_CRON_BACKUP_FILE}"
  trap - EXIT
}

# --------------------------------------------------------------------------
# 3k. Keybase helpers
# --------------------------------------------------------------------------

# Runs 'keybase git gc --force' on the named repo. Whether this actually
# reclaims space on the remote is unverified -- use as a best-effort compaction step.
# Usage: kbgc <repo-name>
if command_exists keybase; then
  kbgc() {
    if [ $# -ne 1 ]; then
      error "$(red 'Usage:') ${0} $(yellow '<repo name>')\n For eg: '\$KEYBASE_HOME_REPO_NAME' or '\$KEYBASE_PROFILES_REPO_NAME'"
      return
    fi
    keybase git gc --force "${1:-}"
  }
fi

# --------------------------------------------------------------------------
# 3l. System maintenance
# --------------------------------------------------------------------------

# delete all personal data before re-imaging the laptop
implode() {
  sudo rm -rfv "${HOME}"/.[a-z]*

  local folders=(
    "${ANTIDOTE_HOME}"
    "${ANTIDOTE_PLUGIN_ZSH}"
    "${DOTFILES_DIR}"
    "${HOMEBREW_BUNDLE_FILE}"
    "${HOME}/*.log"
    "${HOME}/personal"
    "${PROJECTS_BASE_DIR}"
  )
  for f in "${folders[@]}"; do
    sudo rm -rfv "${f}"*
  done
}

