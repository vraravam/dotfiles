# file location: ${HOME}/.gitconfig

# Note:
# [Windows users] If you are on windows, please search for the word 'windows' - and fix those lines - they seem to cause some trouble
# [General] Since I use 'delta' as the diffing/pager tool, it's absence on your system will cause some errors. If you are able to, I would sincerely urge you to install and use it for a much better experience. If not, please replace all such occurrences back to use 'diff'

[advice]
  statusHints = true
[alias]
  # ═══════════════════════════════════════════════════════════════════════════
  # HELPER PREDICATES (alphabetical)
  # ═══════════════════════════════════════════════════════════════════════════

  # Lists all local branches and remote-tracking branches (excludes tags and stash).
  # Returns refnames in format 'refs/heads/branch' and 'refs/remotes/origin/branch'.
  # Usage: git all-refs [<dir>]
  all-refs = "!f() { \
    git -C \"${1:-.}\" for-each-ref --format='%(refname)' refs/heads refs/remotes; \
  }; f"

  # Returns 0 if 'upstream' remote exists, 1 otherwise.
  # Usage: git has-upstream [<dir>]
  has-upstream = "!f() { \
    git -C \"${1:-.}\" remote | /usr/bin/grep -x upstream &>/dev/null; \
  }; f"

  # Returns 0 if working tree is clean (no unstaged or staged changes), 1 otherwise.
  # Usage: git is-clean [<dir>]
  is-clean = "!f() { \
    git -C \"${1:-.}\" d --quiet && git -C \"${1:-.}\" dc --quiet; \
  }; f"

  # Returns 0 if working tree has uncommitted changes, 1 if clean.
  # Uses st-nolock for lock-free status check (safe for prompts/monitoring).
  # Usage: git is-dirty [<dir>]
  is-dirty = "!f() { \
    git -C \"${1:-.}\" st-nolock | /usr/bin/grep -q .; \
  }; f"

  # Returns 0 if repo is shallow (partial clone), 1 if it's a full clone.
  # Usage: git is-shallow [<dir>]
  is-shallow = "!f() { \
    git -C \"${1:-.}\" rev-parse --is-shallow-repository | /usr/bin/grep -q true; \
  }; f"

  # Returns porcelain status output without locks (safe for prompts/monitoring).
  # Suppresses errors (2>/dev/null) to avoid noise when not in a git repo.
  # Usage: git st-nolock [<dir>]
  st-nolock = "!f() { \
    git -C \"${1:-.}\" --no-optional-locks status --porcelain 2>/dev/null; \
  }; f"

  # ═══════════════════════════════════════════════════════════════════════════
  # INSPECTION & INFO (alphabetical)
  # ═══════════════════════════════════════════════════════════════════════════

  # Lists branches (add -a for all, -r for remote).
  # Usage: git b [-a|-r]
  b = branch

  # Comprehensive repo size analysis including biggest objects, blobs, trees, commits.
  # Uses git-sizer for detailed breakdown. Shows top 30 lines of output.
  # Usage: git big [<dir>]
  big = "!f() { \
    cd \"${1:-.}\" && git-sizer --verbose | head -30; \
  }; f"

  # Prints the current branch name.
  # Usage: git br
  br = branch --show-current

  # Compresses the repo and reclaims disk space by pruning, repacking, and running gc.
  # Note: refs/stash is intentionally excluded from reflog expire to preserve stashes.
  # --expire and --expire-unreachable use the same window (default: 1.week.ago) so
  # reachable and unreachable commits (rebases, amends, deleted branches) all get the
  # same 1-week recovery window. --stale-fix is always applied to prune broken entries.
  # All other flags (e.g. --dry-run, --verbose) are passed to 'git reflog expire'.
  # The first argument is treated as <dir> if it does not start with '-'; flags follow.
  # Usage: git cc [<dir>] [--expire=<when>] [<extra-reflog-flags>]
  # Example: git cc --expire=now          (expire entire reflog immediately)
  # Example: git cc --expire=3.days.ago   (expire entries older than 3 days)
  # Example: git cc /path/to/repo --expire=now
  cc = "!f() { \
    case \"${1:-}\" in \
      -*|'') dir='.' ;; \
      *) dir=\"${1:-}\"; shift ;; \
    esac; \
    expire=''; \
    rest=(); \
    for a in \"$@\"; do \
      case \"${a}\" in \
        --expire=*) expire=\"${a#--expire=}\" ;; \
        *) rest+=(\"${a}\") ;; \
      esac; \
    done; \
    [ -n \"${expire}\" ] || expire=1.week.ago; \
    refs=$(git -C \"${dir}\" all-refs); \
    git -C \"${dir}\" size; \
    git -C \"${dir}\" remote prune origin; \
    git -C \"${dir}\" pack-refs --all; \
    git -C \"${dir}\" repack -a -d -F --depth=250 --window=250; \
    [ -n \"${refs}\" ] && \
      git -C \"${dir}\" reflog expire --expire=\"${expire}\" --expire-unreachable=\"${expire}\" --stale-fix \"${rest[@]}\" ${refs}; \
    git -C \"${dir}\" maintenance run --task=gc; \
    git -C \"${dir}\" size; \
  }; f"

  # Shows dangling commits (unreachable objects).
  # Usage: git dangling
  dangling = fsck --no-reflog

  # Prints the default branch name of the repo (e.g. main or master) from origin/HEAD.
  # Usage: git default-branch [<dir>]
  # another way: git remote show origin | sed -n '/HEAD branch/s/.*: //p'
  default-branch = "!f() { \
    git -C \"${1:-.}\" symbolic-ref refs/remotes/origin/HEAD | sed 's|refs/remotes/origin/||'; \
  }; f"

  # Deletes all local branches whose remote-tracking counterpart has been deleted (gone).
  # Usage: git dlb [<dir>]
  dlb = "!f() { \
    git -C \"${1:-.}\" branch -vv | /usr/bin/grep ': gone]' | awk '{print $1}' | xargs -r git -C \"${1:-.}\" branch -D; \
  }; f"

  # Opens the global git config file in the default editor.
  # Usage: git ec
  ec = config --global -e

  # Finds tracked files whose name contains the given string (case-insensitive).
  # Usage: git f <pattern>
  # Example: git f "config"
  f = !git ls-files | /usr/bin/grep -i

  # Greps tracked files case-insensitively, ignoring binary files.
  # Usage: git grep <pattern>
  # Example: git grep "TODO"
  grep = grep -Ii --line-number --break

  # Lists the 10 largest files tracked in HEAD by size.
  # Usage: git large [<dir>]
  large = "!f() { \
    git -C \"${1:-.}\" ls-tree -r -t -l --full-name HEAD | sort -n -k 4 | tail -n 10; \
  }; f"

  # Prints remote branches sorted by most-recently-committed with commit details.
  # Usage: git lc
  lc = !git branch -r --sort=-committerdate --format='%(color:magenta)%(committerdate:relative)%(color:reset) %(color:bold cyan)%(refname:short)%(color:reset) %(contents:subject) %(color:bold blue) <%(authorname)> %(color:reset)'

  # Reports whether the specified remote branch has had any commits in the past 10 days.
  # Prints a warning if the branch appears stale (no recent commits).
  # Defaults to the current branch and its tracked remote (falls back to 'origin' if no tracking set).
  # Usage: git old [<remote> <branch>]
  # Example: git old origin feature/old-experiment
  # old = "!f() { [ ... ] && git push ${1} --delete ${2}; }; f"   # uncomment to also delete the branch
  old = "!f() { \
    case \"${1:-}\" in \
      \"\") \
        b=$(git br); \
        remote=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null | cut -d/ -f1); \
        r=${remote:-origin} \
        ;; \
      *) \
        r=\"${1:-}\"; \
        b=\"${2:-}\" \
        ;; \
    esac; \
    [ \"$(git log \"${r}/${b}\" --since 10.days -1 -- 2>/dev/null | wc -l | xargs)\" -eq 0 ] && \
      printf \"Will need to delete %s/%s\n\" \"${r}\" \"${b}\"; \
  }; f"

  # Lists remote branches sorted by oldest commit date.
  # Usage: git oldest-branch [<refbranch> [<count>]]
  oldest-branch = "!f() { \
    refbranch=\"${1:-origin/$(git default-branch)}\" count=\"${2:-20}\"; \
    git for-each-ref --sort=committerdate refs/remotes \
      --format='%(refname:short)|%(HEAD)%(color:yellow)%(refname:short)|%(color:bold green)%(committerdate:relative)|%(color:blue)%(subject)|%(color:magenta)%(authorname)%(color:reset)' \
      --color=always --count=${count} | \
    while IFS= read -r line; do \
      branch=$(printf '%s' \"${line}\" | awk 'BEGIN { FS = \"|\" }; { print $1 }' | tr -d '*'); \
      ahead=$(git rev-list --count \"${refbranch}..${branch}\"); \
      behind=$(git rev-list --count \"${branch}..${refbranch}\"); \
      colorline=$(printf '%s' \"${line}\" | sed 's/^[^|]*|//'); \
      printf '%s' \"${ahead}|${behind}|${colorline}\" | awk -F'|' -vOFS='|' '{$5=substr($5,1,70)}1'; \
    done | \
    ( printf 'ahead|behind||branch|lastcommit|message|author\n\n' && cat ) | \
    column -ts'|'; \
  }; f"

  # Lists remote branches sorted by most-recently-committed, with ahead/behind counts vs the default branch.
  # Optionally specify a different reference branch and/or a count.
  # Usage: git recent-branch [<refbranch> [<count>]]
  # Example: git recent-branch origin/main 30
  recent-branch = "!f() { \
    refbranch=\"${1:-origin/$(git default-branch)}\" count=\"${2:-20}\"; \
    git for-each-ref --sort=-committerdate refs/remotes \
      --format='%(refname:short)|%(HEAD)%(color:yellow)%(refname:short)|%(color:bold green)%(committerdate:relative)|%(color:blue)%(subject)|%(color:magenta)%(authorname)%(color:reset)' \
      --color=always --count=${count} | \
    while IFS= read -r line; do \
      branch=$(printf '%s' \"${line}\" | awk 'BEGIN { FS = \"|\" }; { print $1 }' | tr -d '*'); \
      ahead=$(git rev-list --count \"${refbranch}..${branch}\"); \
      behind=$(git rev-list --count \"${branch}..${refbranch}\"); \
      colorline=$(printf '%s' \"${line}\" | sed 's/^[^|]*|//'); \
      printf '%s' \"${ahead}|${behind}|${colorline}\" | awk -F'|' -vOFS='|' '{$5=substr($5,1,70)}1'; \
    done | \
    ( printf 'ahead|behind||branch|lastcommit|message|author\n\n' && cat ) | \
    column -ts'|'; \
  }; f"

  # Prints the name of the current remote repo (assumes remote named 'origin').
  # Usage: git origin-name [<dir>]
  origin-name = "!f() { \
    basename \"$(git -C \"${1:-.}\" remote get-url origin)\"; \
  }; f"

  # Expires the entire reflog immediately (maximises cleanup when followed by 'git cc').
  # --stale-fix prunes broken reflog entries pointing to missing objects.
  # Note: refs/stash is intentionally excluded to preserve stashes.
  # Usage: git rfc [<dir>]
  rfc = "!f() { \
    refs=$(git -C \"${1:-.}\" all-refs); \
    [ -n \"${refs}\" ] && git -C \"${1:-.}\" reflog expire --expire=now --expire-unreachable=now --stale-fix ${refs}; \
  }; f"

  # Prunes the local copy of remote-tracking branches deleted on origin.
  # Note: fetch.prune=true makes this a no-op after any fetch — useful as an explicit
  # one-shot command without needing to run a full fetch first.
  # Usage: git rpo
  rpo = remote prune origin

  # Searches for a fixed string across the full history of all commits (not just the working tree).
  # Usage: git se <pattern>
  # Example: git se "API_KEY"
  se = "!git rev-list --all -z | xargs -0 git grep -F"

  # Prints the disk size of the current repo's .git directory.
  # Usage: git size [<dir>]
  # Set GIT_SIZE_QUIET=1 to suppress the label (for use in prompts/scripts).
  size = "!f() { \
    root=$(git -C \"${1:-.}\" rev-parse --show-toplevel); \
    size=$(/usr/bin/du -sh \"${root}/.git\" | cut -f1); \
    if [ -n \"${GIT_SIZE_QUIET:-}\" ]; then \
      printf '%s\n' \"${size}\"; \
    else \
      printf '==> Size of repository at %s: %s\n' \"${root}\" \"${size}\"; \
    fi; \
  }; f"

  # Shows the working tree status.
  # Usage: git st
  st = status

  # Shows a short branch+status summary (branch name and per-file status flags).
  # Usage: git sts
  sts = status -sb

  # Shows working tree status along with submodule summary.
  # Usage: git stsub [<dir>]
  stsub = "!f() { \
    git -C \"${1:-.}\" st && git -C \"${1:-.}\" submodule summary; \
  }; f"

  # Shows the upstream tracking branch for the current branch in <remote>/<branch> format.
  # Usage: git track
  track = rev-parse --abbrev-ref --symbolic-full-name @{u}

  # ═══════════════════════════════════════════════════════════════════════════
  # VIEWING CHANGES & HISTORY (alphabetical)
  # ═══════════════════════════════════════════════════════════════════════════

  # Shows unstaged changes (diff of working tree vs index).
  # Usage: git d [<path>]
  d = diff

  # Shows staged changes (diff of index vs last commit).
  # Usage: git dc [<path>]
  dc = d --staged

  # Shows d with changed words highlighted inline (red=deleted, green=added).
  # Usage: git dcolor [<path>]
  dcolor = d --color-words
  # dw = d --word-diff=color           # Note: Commented out since we use delta; but keeping for reference
  # dcw = d --word-diff=color --staged # Note: Commented out since we use delta; but keeping for reference

  # Shows incoming commits (remote → local), without file diffs.
  # Usage: git in
  in = log --reverse ..@{u} --stat --no-merges

  # Shows incoming changes as a single combined diff (not per-commit).
  # Usage: git inc
  inc = d ..@{u}

  # Shows incoming commits with full file diffs.
  # Usage: git inp
  inp = log -p --reverse ..@{u} --no-merges

  # Shows a colorful commit graph for the current branch.
  # Usage: git lg
  lg = log --color --graph --pretty=format:'%C(yellow)%h%Creset -%C(bold blue)%d%Creset %s %C(green) %an, %cr%Creset' --abbrev-commit

  # Shows a colorful commit graph for all branches.
  # Usage: git lga
  lga = log --color --graph --all --pretty=format:'%C(yellow)%h%Creset -%C(bold blue)%d%Creset %s %C(green) %an, %cr%Creset' --abbrev-commit

  # Shows a compact decorated one-line graph log.
  # Usage: git ll
  ll = log --decorate --graph --oneline --abbrev-commit

  # [WIP/DUPLICATE] Like 'lc' but uses 'git log' so a --since date filter can be applied.
  # Usage: git lt
  lt = log --color --graph --pretty=format:'%Cred%h%Creset %C(bold)%(trailers:key=Refs,valueonly,separator=%x2c)%Creset - %s %Cgreen(%cr)%C(bold blue) <%an>%C(nobold yellow)%d%Creset' --abbrev-commit

  # Shows new commits on a branch since the last pull (useful after 'git pull').
  # Defaults to the current branch if no argument is given.
  # Usage: git new [<branch>]
  # Example: git new main
  new = "!f() { \
    b=\"${1:-$(git br)}\"; \
    [ -n \"${1:-}\" ] && shift; \
    git log \"${b}@{1}\"..\"${b}@{0}\" \"$@\"; \
  }; f"

  # Shows commits in the local branch not yet pushed to remote (outgoing), without file diffs.
  # Usage: git out
  out = log --reverse @{u}..

  # Shows outgoing commits with full file diffs.
  # Usage: git outp
  outp = log -p --reverse @{u}..

  # Outputs a plain unified diff (bypassing delta) suitable for use as a patch file.
  # Usage: git patch [<dir>] [<path>] > my.patch
  patch = "!f() { \
    git --no-pager -C \"${1:-.}\" d --no-color; \
  }; f"

  # Shows a compact one-line summary of a commit: hash, subject, and date.
  # Usage: git what [<ref>]
  # Example: git what HEAD
  what = show -s --pretty='tformat:%h (%s, %ad)' --date=short

  # Prints the current user's configured name and email.
  # With an optional <dir> argument, reads from that repo's local config instead.
  # Usage: git who [<dir>]
  who = "!f() { \
    git -C \"${1:-.}\" config --get user.name && git -C \"${1:-.}\" config --get user.email; \
  }; f"

  # ═══════════════════════════════════════════════════════════════════════════
  # LOCAL CHANGES & STAGING (alphabetical)
  # ═══════════════════════════════════════════════════════════════════════════

  # Amends the last commit and updates its timestamp to now.
  # Usage: git amend
  amend = commit --amend --date="now"

  # Amends the last commit silently, keeping the same message, updating timestamp to now.
  # Usage: git amq
  amq = amend --no-edit --quiet

  # Creates a commit with the given message.
  # Usage: git ci "<message>"
  # Example: git ci "feat: add login page"
  ci = commit -m

  # Clones a repository.
  # Usage: git cl <url>
  # Example: git cl git@github.com:user/repo.git
  cl = clone

  # Cherry-picks a commit without auto-committing.
  # Usage: git cn <commit>
  # Example: git cn abc1234
  cn = cherry-pick --no-commit

  # Checks out a branch or file.
  # Usage: git co <branch>
  # Example: git co main
  co = checkout

  # Cherry-picks a commit and commits it immediately.
  # Usage: git cr <commit>
  # Example: git cr abc1234
  cr = cherry-pick

  # Merges a branch without auto-committing (lets you inspect/edit before committing).
  # --no-ff is required since merge.ff=only is set globally.
  # Usage: git mn <branch>
  # Example: git mn feature/foo
  mn = merge --no-commit --no-ff

  # Prints the next patch version derived from the most recent tag (via 'git describe --tags').
  # If the most recent tag is 1.2.3 and there are 5 commits since then, outputs 1.2.9 (3+5+1).
  # Usage: git next-version [<dir>]
  next-version = "!f() { \
    tag=$(git -C \"${1:-.}\" describe --tags --abbrev=0 2>/dev/null); \
    if [ -z \"${tag}\" ]; then printf 'No tags found. Create one first (e.g. git tag 1.0.0)\n' >&2; exit 1; fi; \
    major=$(printf '%s' \"${tag}\" | cut -d. -f1); \
    minor=$(printf '%s' \"${tag}\" | cut -d. -f2); \
    patch=$(printf '%s' \"${tag}\" | cut -d. -f3); \
    commits=$(git -C \"${1:-.}\" rev-list \"${tag}..HEAD\" --count 2>/dev/null); \
    patch=$(( ${patch:-0} + ${commits:-0} + 1 )); \
    printf '%s.%s.%s\n' \"${major}\" \"${minor}\" \"${patch}\"; \
  }; f"

  # Smart commit: if there's exactly 1 unpushed commit (and not diverged), amends it;
  # otherwise (0 unpushed, 2+ unpushed, or diverged), creates a new commit.
  # Aborts if nothing is staged.
  # Uses git rev-list --count for ahead/diverged detection (locale-independent);
  # git status output is locale-dependent and breaks on non-English installations.
  # Usage: git sci "<message>"
  # Example: git sci "fix: correct typo in README"
  sci = "!f() { \
    if git dc --quiet; then \
      printf 'Nothing staged: aborting\n'; \
    elif [ \"$(git rev-list --count @{u}..HEAD 2>/dev/null || echo 0)\" -eq 1 ] \
      && [ \"$(git rev-list --count HEAD..@{u} 2>/dev/null || echo 0)\" -eq 0 ]; then \
      printf 'Amending existing commit (1 unpushed commit)\n'; \
      git amq; \
    else \
      printf 'Creating new commit\n'; \
      git ci \"${1:-}\"; \
    fi; \
  }; f"

  # Unstages all staged changes without discarding them.
  # Usage: git unstage [<path>]
  # Example: git unstage src/foo.ts
  unstage = restore --staged

  # Untracks a file from git without deleting it from disk.
  # Usage: git untrack <path>
  # Example: git untrack config/secrets.yml
  untrack = rm -rf --cached --

  # Stashes ALL changes (staged+unstaged+untracked) as a hidden reflog commit, then hard-resets.
  # The savepoint can be recovered via 'git reflog' if needed.
  # Usage: git wipe [<dir>]
  wipe = "!f() { \
    git -C \"${1:-.}\" add -A && \
      git -C \"${1:-.}\" commit -qm 'WIPE SAVEPOINT if needed later, can be resurrected using reflog' && \
      git -C \"${1:-.}\" reset HEAD~1 --hard; \
  }; f"

  # ═══════════════════════════════════════════════════════════════════════════
  # REMOTE OPERATIONS (alphabetical)
  # ═══════════════════════════════════════════════════════════════════════════

  # Fetches all remotes; if the repo is shallow, unshallows it first. Accepts extra git-fetch flags.
  # Usage: git fetch-unshallow [<extra-flags>]
  # Example: git fetch-unshallow --tags
  fetch-unshallow = "!f() { \
    git is-shallow && git fetch --unshallow \"$@\" || \
    git fetch \"$@\"; \
  }; f"

  # Fetches all remotes and tags, then prunes local branches deleted on remote.
  # Note: --all/--tags/--prune flags are omitted — fetch.all, fetch.pruneTags, and
  # fetch.prune=true in config make plain 'git fetch' equivalent to 'git fetch --all --tags --prune'.
  # Usage: git fo [<dir>]
  fo = "!f() { \
    git -C \"${1:-.}\" fetch && git -C \"${1:-.}\" dlb; \
  }; f"

  # Fetches all remotes, then rebases onto @{u} only if the working tree is clean
  # (no uncommitted or staged changes). If the tree is dirty, skips the rebase,
  # prints a message to stderr, and exits non-zero — callers such as run-all.rb
  # surface this as a per-repo warning so the user knows to pull manually.
  # Designed for cron: a dirty skip is surfaced as a warning, not silently dropped.
  # Usage: git pull-safe [<dir>]
  pull-safe = "!f() { \
    git -C \"${1:-.}\" fetch; \
    if git -C \"${1:-.}\" is-clean; then \
      git -C \"${1:-.}\" rebase '@{u}'; \
    else \
      printf 'Skipping rebase in %s: working tree has uncommitted changes. Pull manually.\n' \"${1:-.}\" >&2; \
      exit 1; \
    fi; \
  }; f"

  # Pulls all remotes; if the repo is shallow, unshallows it first. Accepts extra git-pull flags.
  # Usage: git pull-unshallow [<extra-flags>]
  # Example: git pull-unshallow --rebase
  pull-unshallow = "!f() { \
    git is-shallow && git pull --unshallow \"$@\" || \
    git pull \"$@\"; \
  }; f"

  # Pulls all submodules (runs pull-unshallow in each submodule).
  # Usage: git pullsub
  pullsub = sf "git pull-unshallow"

  # Pushes current branch with submodules.
  # Usage: git pushsub
  pushsub = push --recurse-submodules=on-demand

  # Full upstream rebase workflow: fetches unconditionally, then rebases from upstream (if present),
  # sets tracking, pushes, updates submodules, and prunes gone branches — but only if the working
  # tree is clean. A dirty tree skips everything after the fetch to avoid a mid-workflow failure
  # (after rebase but before push) that would leave the repo in an inconsistent state.
  # If no upstream remote exists, rebases from origin instead (gracefully falls back for non-fork repos).
  # Callers (e.g. run-all.rb in cron) receive a non-zero exit and surface a warning on dirty tree.
  # Usage: git upreb [<dir>]
  upreb = "!f() { \
    git -C \"${1:-.}\" fetch; \
    if git -C \"${1:-.}\" is-clean; then \
      git -C \"${1:-.}\" branch -u \"origin/$(git -C \"${1:-.}\" br)\"; \
      if git -C \"${1:-.}\" has-upstream; then \
        git -C \"${1:-.}\" rebase \"upstream/$(git -C \"${1:-.}\" br)\" --no-verify && \
          git -C \"${1:-.}\" fetch upstream --tags; \
      else \
        git -C \"${1:-.}\" rebase \"origin/$(git -C \"${1:-.}\" br)\" --no-verify; \
      fi && \
      git -C \"${1:-.}\" push --no-verify && \
      git -C \"${1:-.}\" push --tags --no-verify && \
      git -C \"${1:-.}\" siu && \
      git -C \"${1:-.}\" dlb; \
    else \
      printf 'Skipping rebase/push in %s: working tree has uncommitted changes. Run manually.\n' \"${1:-.}\" >&2; \
      exit 1; \
    fi; \
  }; f"

  # ═══════════════════════════════════════════════════════════════════════════
  # SUBMODULES (alphabetical)
  # ═══════════════════════════════════════════════════════════════════════════

  # Runs a command in each submodule.
  # Usage: git sf <command>
  # Example: git sf git status
  sf = submodule foreach

  # Initialises and updates all submodules recursively (use after a fresh clone or pull).
  # Usage: git siu
  siu = submodule update --init --recursive --remote --rebase --force

  # undo the last N commits (1 by default) - provided by git-extras
  # Usage: git undo [<N>]
  # Example: git undo 3

  # show all committers' info summary (count and name) - use 'git summary' from git-extras for richer output
  # committers = shortlog -s --

  # show username/email of the specified author - use 'git who <author>' from git-extras
  # whois = log -i -1 --pretty=format:'%an <%ae>' --author

  # standup - use 'git standup' from git-extras (supports multi-repo search, flexible time ranges)
  # Example: git standup -d 7        (last 7 days)
  # Example: git standup -d 7 -m 3   (last 7 days, search 3 levels deep)
  # Example: git standup -d 7 -a all (last 7 days, all authors)

[branch]
  autoSetupMerge = true
  autoSetupRebase = always
  sort = -committerdate # sort branches by commit date (latest first)
[checkout]
  defaultRemote = origin
  workers = 0
[clean]
  requireForce = true
[clone]
  rejectShallow = true
[color "diff"]
  commit = yellow bold
  frag = magenta bold
  func = 146 bold
  meta = yellow
  new = green bold
  old = red bold
  whitespace = red reverse
[column]
  # ui = auto
[commit]
  # verbose = true
[core]
  autocrlf = false
  commentChar = *
  bigFileThreshold = 512m          # skip delta compression for files larger than this (faster pack, smaller packs for binary-heavy repos)
  compression = 9                  # max zlib compression for loose objects (best size reduction)
  excludesFile = ~/.gitignore_global
  fileMode = true
  fsMonitor = true
  logAllRefUpdates = true
  longPaths = true
  # pager setting moved to ~/.gitconfig-delta.inc (conditionally included when delta is installed)
  # repositoryFormatVersion = 1   # Note: This can be uncommented to enable the new repository format for SHA256 support
  sshCommand="ssh -o ConnectTimeout=20"
  symlinks = false
  untrackedCache = true
  whitespace = fix
[diff]
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true
  renameLimit = 1000
  renames = true
  submodule = diff
[diff "pandoc"]
  textconv = pandoc --sandbox --to=markdown
# Delta configuration moved to ~/.gitconfig-delta.inc (conditionally included when delta is installed)
[extensions]
  # objectFormat = sha256         # Note: This can be uncommented to enable the new repository format for SHA256 support
  # compatObjectFormat = sha1     # Note: This can be uncommented to enable the new repository format for SHA256 support
[feature]
  manyFiles = true                # Enables optimizations (fsmonitor, untrackedCache) for repos with many files
[fetch]
  all = true
  negotiationAlgorithm = skipping # faster fetch negotiation for repos with long histories (skips exponentially)
  parallel = 0
  prune = true
  pruneTags = true
  showForcedUpdates = true
  writeCommitGraph = true
[filter "lfs"]
  clean = git-lfs clean -- %f
  process = git-lfs filter-process
  required = true
  smudge = git-lfs smudge -- %f
[gc]
  auto = 2000
  pruneExpire = now
  reflogExpire = 2.weeks.ago
  reflogExpireUnreachable = 2.weeks.ago
  rerereResolved = 1.weeks.ago
  worktreePruneExpire = 1.weeks.ago
[grep]
  column = true
  extendedRegexp = true
  fullName = true
  lineNumber = true
[gui]
  matchTrackingBranch = true
  pruneDuringFetch = true
  tabSize = 2
  warnDetachedCommit = true
[help]
  autoCorrect = prompt
[http]
  lowSpeedLimit = 1000
  lowSpeedTime = 30
  postBuffer = 786432000
  version = HTTP/2                 # use HTTP/2 for multiplexed, header-compressed push/pull
[index]
  version = 4                     # More efficient index format with path prefix compression
[init]
  defaultBranch = master
  defaultRefFormat = reftable
# [interactive] section moved to ~/.gitconfig-delta.inc (conditionally included when delta is installed)
[maintenance]
  auto = true
  strategy = incremental
[log]
  decorate = auto
  # abbrevCommit = true
[merge]
  autoStash = true
  conflictStyle = zdiff3
  # conflictStyle = diff3
  defaultToUpstream = true
  ff = only
  renameLimit = 15000
[pack]
  compression = 9                  # max zlib compression inside packfiles (primary knob for pack size)
  deltaCacheSize = 2047m           # larger delta cache = better delta chains during repack = smaller packs
  threads = 0                      # auto-detect CPU count
  useDeltaBaseOffset = true        # use delta-base offsets (smaller packs; supported by all modern git clients)
  windowMemory = 1g                # memory per thread during pack window search; more = better compression
  writeReverseIndex = true
[pager]
  # Note: The '--pattern' switch sets some pre-search terms, but also scrolls to fill the whole console for single line change - which I dont like.
  diff = delta  # --pattern '^(Date|added|deleted|modified|renamed): '    # windows
[pull]
  autoStash = true
  rebase = true
[push]
  autoSetupRemote = true
  default = upstream
  followTags = true
  recurseSubmodules = check
[rebase]
  abbreviateCommands = true
  autoSquash = true
  autoStash = true
  missingCommitsCheck = error
  updateRefs = true
[protocol]
  version = 2                      # git protocol v2: faster ls-refs / fetch negotiation (avoids sending all refs)
[repack]
  MIDXMustContainCruft = true
  packKeptObjects = false          # do not repack .keep packs (avoids repackaging intentionally-held packs)
  useDeltaBaseOffset = true        # smaller packfiles (mirrors pack.useDeltaBaseOffset for repack operations)
[rerere]
  autoUpdate = true
  enabled = true
[stash]
  showIncludeUntracked = true
  showPatch = true
  untracked = true
[status]
  branch = true
  showStash = true
  showUntrackedFiles = all
  # Convert to 'true' in case you work with submodules - but, will have visible perf slowdown
  submoduleSummary = false     # windows
[submodule]
  fetchJobs = 0
  # recurse = true
[tag]
  sort = -version:refname   # sort tags by version number (descending)
[transfer]
  fsckObjects = true
[user]
  useConfigOnly = true

# moved BELOW all the above sections so that the per-folder includes can override the global settings
# Note: Even though configs from this file will show up twice in `git config -l` - it will still be overridden based on the order of the include/includeIf lines below (last matching configuration wins).
[include]
  # Delta-specific configuration
  # Note: Git's includeIf doesn't support PATH checks. Instead, we use a symlink approach:
  # The install-dotfiles script creates ~/.gitconfig-delta-enabled.inc as a symlink to
  # ~/.gitconfig-delta.inc when delta is installed and removes it if not found. This file
  # is always included, but only exists when delta is present.
  path = ~/.gitconfig-delta-enabled.inc
  path = ~/.gitconfig-oss.inc
