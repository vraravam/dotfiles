#!/usr/bin/env zsh

# vim:filetype=zsh syntax=zsh tabstop=2 shiftwidth=2 softtabstop=2 expandtab autoindent fileencoding=utf-8

# Compresses a git repo and reclaims disk space (prune, repack, gc).
# Wraps 'git cc'. All --flags are forwarded to 'git reflog expire'.
#
# Usage: cc [<folder>] [--expire=<when>] [<extra-reflog-flags>]
#
# --expire defaults to 1.week.ago and applies to both reachable and unreachable
# entries (rebases, amends, deleted branches). --stale-fix is always applied.
#
# Examples:
#   cc                          # current dir, expire=1.week.ago
#   cc /path/to/repo            # explicit folder, expire=1.week.ago
#   cc --expire=now             # expire entire reflog immediately
#   cc /path/to/repo --expire=3.days.ago
#   cc --dry-run                # preview what would be pruned

# Re-source guard is inside .shellrc itself -- safe to call unconditionally.
source "${HOME}/.shellrc"

_cc() {
  local folder
  local -a switches
  parse_folder_and_switches "$@"
  section_header2 "$(yellow 'Compressing') $(purple "${folder}")"
  if ! is_git_repo "${folder}"; then
    warn "Skipping finding size of the repo since '$(yellow "${folder}")' doesn't exist or is not a git repo"
  else
    git -C "${folder}" cc "${switches[@]}" || true
  fi
}

cc() {
  # Guard against race condition when .aliases is deferred via zsh-defer: if
  # dispatch_or_fallback doesn't exist yet (multiple tabs opening simultaneously),
  # load .aliases synchronously now. The re-source guard in .aliases makes this safe.
  if ! (( $+functions[dispatch_or_fallback] )); then
    source "${HOME}/.aliases"
  fi
  dispatch_or_fallback cc _cc "$@"
}

# Run only when executed directly, not when sourced (e.g. to import the function into another script).
[[ "${zsh_eval_context}" == *file* ]] || cc "$@"
# is_zsh returns false in bash (ZSH_VERSION unset), short-circuiting the zsh-only
# '(( $+functions[...] ))' syntax so it is never evaluated by non-zsh runtimes.
is_zsh && (($+functions[compdef])) && compdef cc || true
