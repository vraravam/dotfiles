#!/usr/bin/env zsh

# vim:filetype=zsh syntax=zsh tabstop=2 shiftwidth=2 softtabstop=2 expandtab autoindent fileencoding=utf-8

# git command: push

# Re-source guard is inside .shellrc itself — safe to call unconditionally.
source "${HOME}/.shellrc"

_push() {
  local folder
  local -a switches
  parse_folder_and_switches "$@"
  section_header2 "$(yellow 'Pushing') $(purple "${folder}")"
  if ! is_git_repo "${folder}"; then
    warn "Skipping pushing of the repo since '$(yellow "${folder}")' doesn't exist or is not a git repo"
  else
    git -C "${folder}" push "${switches[@]}" || true
  fi
}

push() { dispatch_or_fallback push _push "$@"; }

# Run only when executed directly, not when sourced (e.g. to import the function into another script).
[[ "${zsh_eval_context}" == *file* ]] || push "$@"
# is_zsh returns false in bash (ZSH_VERSION unset), short-circuiting the zsh-only
# '(( $+functions[...] ))' syntax so it is never evaluated by non-zsh runtimes.
is_zsh && (($+functions[compdef])) && compdef push || true
