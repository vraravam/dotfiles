#!/usr/bin/env zsh

# vim:filetype=zsh syntax=zsh tabstop=2 shiftwidth=2 softtabstop=2 expandtab autoindent fileencoding=utf-8

# Source shell helpers if they aren't already loaded
# Re-source guard is inside .shellrc itself — safe to call unconditionally.
source "${HOME}/.shellrc"

# Updates the specified repo (ie creates a local commit of changed files that I am not interested in verifying, but which need to be committed into that repo)
# internal function: not to be called separately
_update_repo() {
  if ! is_git_repo "${1}"; then
    warn "Skipping updating the repo since '$(yellow "${1}")' doesn't exist or is not a git repo"
    return 0 # Success, nothing to do
  fi

  local folder="$(strip_trailing_slash "${1}")"

  local relative_path="$(git -C "${folder}" relative-path "${2}")"
  relative_path="${relative_path:-.}"

  section_header2 "$(yellow 'Updating') $(purple "${folder}")"
  rm -rfv "${folder}/.git/index.lock" "${folder}/.git/hooks"

  local human_date
  current_timestamp human_date
  git -C "${folder}" add "${relative_path}" && git -C "${folder}" sci "Incremental commit: ${human_date}" || true
}

# Updates the home and profiles repos
update_all_repos() {
  # use full-fledged path (based on env vars for consistency and maintenance)
  _update_repo "${HOME}" "${PERSONAL_CONFIGS_DIR}/defaults"
  _update_repo "${PERSONAL_PROFILES_DIR}" "${PERSONAL_PROFILES_DIR}"
}

# Run only when executed directly, not when sourced (e.g. to import the function into another script).
[[ "${zsh_eval_context}" == *file* ]] || update_all_repos "$@"
# ZSH_VERSION guard ensures the zsh-only '(( $+functions[...] ))' syntax is never
# evaluated by non-zsh runtimes (e.g. direnv's sandbox).
[[ -n "${ZSH_VERSION-}" ]] && (($+functions[compdef])) && compdef update_all_repos || true
