#!/usr/bin/env zsh

# vim:filetype=zsh syntax=zsh tabstop=2 shiftwidth=2 softtabstop=2 expandtab autoindent fileencoding=utf-8

# git command: upreb

# Source shell helpers if they aren't already loaded
# Re-source guard is inside .shellrc itself — safe to call unconditionally.
source "${HOME}/.shellrc"

# Rebases all locally checked-out branches of the specified folder against their upstream. Defaults to the current directory if no folder is specified.
_upreb() {
  local folder="${1:-$(pwd)}"
  section_header2 "$(yellow 'Upreb-ing') $(purple "${folder}")"

  local current_branch="$(git -C "${folder}" br)"
  info "current branch: $(yellow "${current_branch}")"
  local local_branches=("${(@f)$(git -C "${folder}" branch --format='%(refname:short)')}")
  if is_non_empty_array local_branches; then
    # remove the current_branch from the list of branches
    local_branches=("${(@)local_branches:#$current_branch}")
    # add the current branch to the end of the list
    local_branches+=("${current_branch}")

    for branch in "${local_branches[@]}"; do
      debug "processing: $(yellow "${branch}")"
      git -C "${folder}" switch "${branch}"
      git -C "${folder}" upreb || true
      git -C "${folder}" push || true
      echo "$(red "$(print_chars_for_length '-' $COLUMNS)")"
    done
  fi
}

upreb() { dispatch_or_fallback upreb _upreb "$@"; }

# Run only when executed directly, not when sourced (e.g. to import the function into another script).
[[ "${zsh_eval_context}" == *file* ]] || upreb "$@"
# ZSH_VERSION guard ensures the zsh-only '(( $+functions[...] ))' syntax is never
# evaluated by non-zsh runtimes (e.g. direnv's sandbox).
[[ -n "${ZSH_VERSION-}" ]] && (($+functions[compdef])) && compdef upreb || true
