#!/usr/bin/env zsh

# vim:filetype=zsh syntax=zsh tabstop=2 shiftwidth=2 softtabstop=2 expandtab autoindent fileencoding=utf-8

# git command: upreb

# Re-source guard is inside .shellrc itself -- safe to call unconditionally.
source "${HOME}/.shellrc"

# Rebases all locally checked-out branches of the specified dir against their upstream,
# then pushes each branch. Defaults to the current directory if no dir is specified.
_upreb() {
  local dir="${1:-${PWD}}"
  section_header2 "$(yellow 'Upreb-ing') $(purple "${dir}")"

  local current_branch
  current_branch="$(git -C "${dir}" br)"
  info "current branch: $(yellow "${current_branch}")"
  local local_branches=("${(@f)$(git -C "${dir}" branch --format='%(refname:short)')}")
  if is_non_empty_array local_branches; then
    # remove the current_branch from the list of branches
    local_branches=("${(@)local_branches:#${current_branch}}")
    # add the current branch to the end of the list
    local_branches+=("${current_branch}")

    local branch
    for branch in "${local_branches[@]}"; do
      debug "processing: $(yellow "${branch}")"
      git -C "${dir}" switch "${branch}"
      git -C "${dir}" upreb || true
      # If incoming and outgoing commit counts are identical AND git diff @{u}
      # produces no diffs, the branch has diverged symmetrically with no content
      # difference (e.g. remote was force-pushed/rebased). Safe to rebase silently.
      local incoming outgoing
      incoming="$(git -C "${dir}" rev-list HEAD..@{u} --count 2>/dev/null || echo 0)"
      outgoing="$(git -C "${dir}" rev-list @{u}..HEAD --count 2>/dev/null || echo 0)"
      if [[ "${incoming}" -gt 0 && "${incoming}" -eq "${outgoing}" ]] &&
        git -C "${dir}" diff @{u} --quiet 2>/dev/null; then
        info "Symmetric diverge with no content diff -- rebasing $(yellow "${branch}") onto @{u}"
        git -C "${dir}" rebase @{u} || true
      fi
      git -C "${dir}" push || true
      echo "$(red "$(print_chars_for_length '-' $COLUMNS)")"
    done
  fi
}

upreb() {
  # Guard against race condition when .aliases is deferred via zsh-defer: if
  # dispatch_or_fallback doesn't exist yet (multiple tabs opening simultaneously),
  # load .aliases synchronously now. The re-source guard in .aliases makes this safe.
  if ! (($+functions[dispatch_or_fallback])); then
    source "${HOME}/.aliases"
  fi
  dispatch_or_fallback upreb _upreb "$@"
}

# Run only when executed directly, not when sourced (e.g. to import the function into another script).
[[ "${zsh_eval_context}" == *file* ]] || upreb "$@"
# is_zsh returns false in bash (ZSH_VERSION unset), short-circuiting the zsh-only
# '(( $+functions[...] ))' syntax so it is never evaluated by non-zsh runtimes.
is_zsh && (($+functions[compdef])) && compdef upreb || true
