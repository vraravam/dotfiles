#!/usr/bin/env zsh

# vim:filetype=zsh syntax=zsh tabstop=2 shiftwidth=2 softtabstop=2 expandtab autoindent fileencoding=utf-8

# git command: st

# Source shell helpers if they aren't already loaded
type is_shellrc_sourced 2>&1 &> /dev/null || source "${HOME}/.shellrc"

st() {
  local folder="${1:-$(pwd)}"
  section_header "$(yellow 'Checking') $(purple "${folder}")"
  if ! is_git_repo "${folder}"; then
    warn "Skipping finding status of the repo since '$(yellow "${folder}")' doesn't exist or is not a git repo"
  else
    git -C "${folder}" st
  fi
}

st "$@"
compdef st
