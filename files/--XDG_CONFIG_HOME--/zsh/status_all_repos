#!/usr/bin/env zsh

# vim:filetype=zsh syntax=zsh tabstop=2 shiftwidth=2 softtabstop=2 expandtab autoindent fileencoding=utf-8

# Re-source guard is inside .shellrc itself — safe to call unconditionally.
source "${HOME}/.shellrc"
# st is a required dependency; source it to make the function available without
# triggering its self-invocation (zsh_eval_context guard in st prevents execution when sourced).
# Note: load_file_if_exists is intentionally NOT used — st is required, not optional.
source "${XDG_CONFIG_HOME}/zsh/st"

# Reports status of the following repos: HOME, DOTFILES_DIR, PERSONAL_PROFILES_DIR, ZenProfile chrome folder
status_all_repos() {
  st "${HOME}"
  st "${DOTFILES_DIR}"
  st "${PERSONAL_PROFILES_DIR}"
  # Use zsh glob qualifiers to only loop if matches exist and are directories
  # (N) nullglob: if no match, the pattern expands to nothing
  # (/): only match directories
  local chrome_folders=("${PERSONAL_PROFILES_DIR}"/*Profile/Profiles/DefaultProfile/chrome(N/))
  if is_non_empty_array chrome_folders; then
    local folder
    for folder in "${chrome_folders[@]}"; do
      st "${folder}"
    done
  fi
}

# Run only when executed directly, not when sourced (e.g. to import the function into another script).
[[ "${zsh_eval_context}" == *file* ]] || status_all_repos "$@"
# is_zsh returns false in bash (ZSH_VERSION unset), short-circuiting the zsh-only
# '(( $+functions[...] ))' syntax so it is never evaluated by non-zsh runtimes.
is_zsh && (($+functions[compdef])) && compdef status_all_repos || true
