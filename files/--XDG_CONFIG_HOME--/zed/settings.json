// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "github-copilot-cli": {
      "favorite_config_option_values": {
        "mode": [
          "https://agentclientprotocol.com/protocol/session-modes#autopilot"
        ]
      },
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "qwen-code": {
      "type": "registry"
    }
  },
  "buffer_font_family": "MesloLGM Nerd Font",
  "icon_theme": "VSCode Icons for Zed (Dark)",
  "agent": {
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "gpt-5.1-codex-max",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.5",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "claude-opus-4.6",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.4",
        "enable_thinking": false
      },
      {
        "provider": "ollama",
        "model": "deepseek-coder-v2:latest"
      }
    ],
    "play_sound_when_agent_done": true,
    // "single_file_review": false,
    "model_parameters": [],
    "default_model": {
      "enable_thinking": false,
      "provider": "copilot_chat",
      "model": "gpt-5.1-codex-max"
    },
    "default_profile": "write",
    "enabled": true,
    "button": true,
    "dock": "right",
    "default_width": 640,
    "default_height": 320,
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.1-codex-max",
      "enable_thinking": false
    },
    "inline_alternatives": [
      {
        "provider": "zed.dev",
        "model": "claude-sonnet-4"
      },
      {
        "provider": "zed.dev",
        "model": "claude-sonnet-4"
      },
      {
        "provider": "zed.dev",
        "model": "claude-opus-4"
      },
      {
        "provider": "zed.dev",
        "model": "gpt-4o"
      },
      {
        "provider": "zed.dev",
        "model": "gpt-4o-mini"
      },
      {
        "provider": "zed.dev",
        "model": "gemini-2.0-flash"
      },
    ],
    "show_turn_stats": true,
  },
  "disable_ai": false,
  "hard_tabs": false,
  "calls": {
    "mute_on_join": true,
  },
  "status_bar": {
    "cursor_position_button": true,
    "active_language_button": true
  },
  "diagnostics": {
    "button": true
  },
  "terminal": {
    "copy_on_select": true,
    "detect_venv": "off",
    "dock": "bottom",
    // "option_as_meta": false,
    "scrollbar": {
      "show": "always"
    },
    "toolbar": {
      "breadcrumbs": true
    },
    "default_height": 320,
    "keep_selection_on_copy": false,
    "working_directory": "current_project_directory",
    "button": true,
    "blinking": "terminal_controlled",
    // "cursor_shape": "underline",
    // "font_family": "JetBrains Mono NL",
    // "font_size": 14,
    // "font_weight": 400,
  },
  "git_panel": {
    "tree_view": true,
    "sort_by_path": true,
    "status_style": "label_color",
    "collapse_untracked_diff": false
  },
  "title_bar": {
    "show_menus": true,
    "show_branch_icon": true,
    "show_onboarding_banner": true,
    "show_project_items": true,
    "show_branch_name": true,
    "show_sign_in": true,
    "show_user_picture": true,
  },
  "project_panel": {
    "button": true,
    "dock": "left",
    "git_status": true,
    "indent_size": 20,
    "file_icons": true,
    "folder_icons": true,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
    "hide_hidden": false,
    "hide_gitignore": false,
    "sticky_scroll": true,
    "scrollbar": {
      "show": "auto"
    },
    "entry_spacing": "comfortable",
    "hide_root": false,
  },
  "close_on_file_delete": true,
  "current_line_highlight": "all",
  "text_rendering_mode": "platform_default",
  "agent_ui_font_size": 15,
  "pane_split_direction_horizontal": "down",
  "window_decorations": "client",
  "edit_predictions": {
    "provider": "copilot",
    "copilot": {
      "enable_next_edit_suggestions": true
    }
  },
  "selection_highlight": true,
  "rounded_selection": true,
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "show_whitespaces": "selection",
  "show_wrap_guides": true,
  "relative_line_numbers": "disabled",
  "cursor_blink": true,
  "format_on_save": "off",
  "minimap": {
    "show": "always",
    "current_line_highlight": "all",
    "thumb": "always",
    "max_width_columns": 90,
    "display_in": "all_editors",
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "base_keymap": "Atom",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "zoomed_padding": true,
  "centered_layout": {
    "right_padding": null,
    "left_padding": null
  },
  // "pane_split_direction_vertical": "right",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "VSCode Dark Modern",
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
    "show_tab_bar_buttons": true,
    "show_nav_history_buttons": true,
    "show": true
  },
  "when_closing_with_no_tabs": "keep_window_open",
  "preferred_line_length": 120,
  "toolbar": {
    "code_actions": true,
    "breadcrumbs": true
  },
  "soft_wrap": "editor_width",
  "tab_size": 2,
  "active_pane_modifiers": {},
  "preview_tabs": {
    "enable_preview_from_file_finder": true
  },
  "debugger": {
    "button": true
  },
  "helix_mode": false,
  "autosave": "on_focus_change",
  "notification_panel": {
    "button": true
  },
  "outline_panel": {
    "button": true
  },
  // "cursor_shape": "underline",
  "confirm_quit": false,
  "restore_on_startup": "last_workspace",
  "extend_comment_on_newline": true,
  "use_autoclose": true,
  "show_completion_documentation": true,
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "all",
    // "show_close_button": "always",
  },
  "file_scan_exclusions": [
    "**/*.venv",
    "**/*.zwc*",
    "**/.*.zwc*",
    "**/.cache",
    "**/.classpath",
    "**/.direnv",
    "**/.DS_Store",
    "**/.elixir_ls",
    "**/.git",
    "**/.hg",
    "**/.jj",
    "**/.mypy_cache/",
    "**/.repo",
    "**/.ruby-lsp",
    "**/.settings",
    "**/.svn",
    "**/build",
    "**/coverage",
    "**/CVS",
    "**/dist",
    "**/node_modules",
    "**/Thumbs.db",
    "**/tmp",
  ],
  "file_scan_inclusions": [
    "**/.env*",
    "**/reports/**"
  ],
  "enable_language_server": true,
  "inlay_hints": {
    "enabled": true,
    "show_background": false,
    "show_type_hints": false,
    "show_parameter_hints": false,
    "show_other_hints": true,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50
  },
  "indent_guides": {
    "coloring": "fixed",
    "background_coloring": "disabled"
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
      "delay_ms": 600,
      "show_commit_summary": true
    },
    "branch_picker": {
      "show_author_name": true
    },
  },
  "vim_mode": false,
  "use_system_window_tabs": false,
  "bottom_dock_layout": "contained",
  "auto_install_extensions": {
    "colored-zed-icons-theme": true,
    "docker-compose": true,
    "dockerfile": true,
    "editorconfig": true,
    "groovy": true,
    "html": true,
    "ini": true,
    "java": true,
    "javascript": true,
    "json": true,
    "log": true,
    "macos-classic": true,
    "markdown": true,
    "markdownlint": true,
    "ruby": true,
    "scss": true,
    "vscode-dark-modern": true,
    "vscode-icons": true,
    "xml": true,
    "yaml": true,
    // "graphql": true,
    // "nginx": true,
    // "python": true,
    // "rust": true,
    // "shell script": true,
    // "tsx": true,
    // "typescript": true,
  },
  "colorize_brackets": true,
  "completion_menu_scrollbar": "auto",
  "auto_signature_help": true,
  "search": {
    "button": true,
    "include_ignored": true,
    "whole_word": false,
    "case_sensitive": false,
    "regex": false
  },
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "seed_search_query_from_cursor": "selection",
  "scrollbar": {
    "show": "auto",
    "cursors": false,
    "git_diff": true,
    "search_results": true,
    "selected_symbol": true,
    "diagnostics": "all"
  },
  "prettier": {
    "singleQuote": true,
  },
  "languages": {
    "Ruby": {
      "formatter": {
        "external": {
          "command": "rubocop",
          "arguments": ["--stdin", "{buffer_path}", "--autocorrect", "--stderr", "--format", "json"]
        }
      },
      "language_servers": ["ruby-lsp", "!solargraph"],
      "inlay_hints": {
        "enabled": false
      }
    },
    "ERB": {
      "formatter": {
        "external": {
          "command": "erb-formatter",
          "arguments": ["--stdin"]
        }
      }
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll.eslint": true
      },
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TSX": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JSON": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JSONC": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "Markdown": {
      "use_on_type_format": false,
      "prettier": {
        "allowed": true
      }
    },
    "Python": {
      "language_servers": ["ruff"],
      "formatter": [
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ],
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll.ruff": true
      }
    },
    "SCSS": {
      "code_actions_on_format": {
        "source.fixAll.stylelint": true
      },
      "prettier": {
        "allowed": true
      }
    },
    "CSS": {
      "code_actions_on_format": {
        "source.fixAll.stylelint": true
      },
      "prettier": {
        "allowed": true
      }
    },
    "Diff": {
      "remove_trailing_whitespace_on_save": false,
      "ensure_final_newline_on_save": false
    },
    "HTML": {
      "prettier": {
        "allowed": true
      }
    },
    "YAML": {
      "prettier": {
        "allowed": true
      }
    },
    "Shell Script": {
      "formatter": {
        "external": {
          "command": "shfmt",
          // Change `--indent 2` to match your preferred tab_size
          "arguments": ["--apply-ignore", "-ci", "-sr", "-kp", "-i", "2", "--filename", "{buffer_path}"]
        }
      }
    }
  },
  "file_types": {
    "ini": [
      ".gitconfig*",
    ],
    "JSONC": ["*.json"],
    "Shell Script": [
      "**/zsh/*",
      "*.env*",
      "*.sh",
      ".env*",
      ".gitignore*",
    ],
    "Dockerfile": ["Dockerfile*"],
    "Ruby": [
      "*.arb",
      "*.erb",
      "*.gemspec",
      "*.jbuilder",
      "*.rake",
      "*.ru",
      "*.thor",
      ".irbrc",
      ".pryrc",
      "Brewfile",
      "Capfile",
      "Fastfile",
      "Gemfile",
      "Guardfile",
      "Podfile",
      "Rakefile",
      "Thorfile",
      "Vagrantfile",
    ],
    "ERB": ["*.erb", "*.html.erb", "*.heex", "*.leex"],
  },
}
